task _SpellScoreHandling(){

	// Decrease score per frame
	int objScene = GetEnemyBossSceneObjectID();
	int maxSpellScore = GetCommonDataPtr(POINTER_SPELLSCORE, 10000000);
	int minSpellScore = GetCommonDataPtr(POINTER_SPELLSCORE, 10000000)/10;
	int reductionPerFrame = (maxSpellScore - minSpellScore)/ObjEnemyBossScene_GetInfo(objScene, INFO_ORGTIMERF);

	async{
		int frame = 0;
		while(ObjEnemyBossScene_GetInfo(objScene, INFO_CURRENT_LIFE) > 0){
			frame++;
			frame = clamp(frame, 0, ObjEnemyBossScene_GetInfo(objScene, INFO_ORGTIMERF));
			SetCommonDataPtr(POINTER_SPELLSCORE, GetCommonDataPtr(POINTER_SPELLSCORE, 10000000)-reductionPerFrame);
			SetCommonDataPtr(POINTER_SPELLSCORE, clamp(GetCommonDataPtr(POINTER_SPELLSCORE, 10000000), minSpellScore, maxSpellScore));
			yield;
		}
		AddScore(GetCommonDataPtr(POINTER_SPELLSCORE, 10000000));
	}

	// -25% if burst, -50% if take damage
	async{
		while(ObjEnemyBossScene_GetInfo(objScene, INFO_CURRENT_LIFE) > 0){
			if(
				GetPlayerState() == STATE_DOWN &&
				ObjEnemyBossScene_GetInfo(objScene, INFO_TIMERF) <= ObjEnemyBossScene_GetInfo(objScene, INFO_ORGTIMERF) - 30
			){
				SetCommonDataPtr(POINTER_SPELLSCORE, GetCommonDataPtr(POINTER_SPELLSCORE, 10000000) * 0.5);
				wait(90);
			}
			if(
				GetCommonDataPtr(POINTER_BURSTGAUGE, 0) >= 100 &&
				GetVirtualKeyState(VK_SPELL) == KEY_PUSH &&
				GetCommonDataPtr(POINTER_BURSTMODE, false) == false
				)
			{
				SetCommonDataPtr(POINTER_SPELLSCORE, GetCommonDataPtr(POINTER_SPELLSCORE, 10000000) * 0.75);
				wait(90);				
			}
			yield;
		}
	}

}

