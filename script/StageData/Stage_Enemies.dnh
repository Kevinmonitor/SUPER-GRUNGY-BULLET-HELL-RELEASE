function <int> _LargeShip(
	int renderPriority, invinTime, lifeTime,
	float enmX, float enmY, int[] rectArray, float enemyHP, bool cancel
	){

	// Spawns enemy.

	int spd = 5;
	
	int enm = _CreateEnemy(
	enmX, enmY, 
	enmX, enmY, 
	5, 1.0, 1.0,
	enemyHP, largeEnemyHitbox, 0,
	lifeTime,
	texEnm,
	rectArray);
	
	ObjRender_SetTextureFilter(enm, FILTER_NONE, FILTER_NONE, FILTER_NONE);
	Obj_SetRenderPriorityI(enm, renderPriority);
	CreateEnemyLifebar(enm, enemyHP);

	int frame = 0;

	async{

		while(!Obj_IsDeleted(enm)){

			// Deadzone
			invinTime--;
			if(invinTime > 0){ObjEnemy_SetDamageRate(enm, 0.1, 0.1);}
			else{ObjEnemy_SetDamageRate(enm, 1, 1);}

			yield;

		}

	}

	if (cancel) {LargeExplosion_Cancel(enm, 32, 8);}
	else {LargeExplosion(enm, 32, 8);}

	_EnemyItemDrop(
		enm,
		medFlyingEnm_itemPointMin, medFlyingEnm_itemPointMax,
		medEnemyHitbox
	);
	
	return enm;
	
}

function CreateLargeSpinningEnemy(
	int renderPriority, invinTime,
	float enmX, float enmY, 
	float startAng,
	float angChangeSpeed,
	float startScale, float endScale,
	float startAlpha, float endAlpha,
	float startSpaceX, float startSpaceY,
	float endSpaceX, float endSpaceY,
	float spaceMovementTime,
	int leaveTime,
	int[] rectArray, float enemyHP
	){


	// lifetime is 99999 to prevent the enemy just randomly exploding

	float spaceX = startSpaceX;
	float spaceY = startSpaceY;

	int enm = _LargeShip(
		renderPriority, invinTime, 99999,
		enmX, enmY, rectArray, enemyHP
	);

	// movement
	async{

		while(!Obj_IsDeleted(enm)){

			ObjMove_SetPosition(enm, enmX + spaceX * cos(startAng), enmY + spaceY * sin(startAng));
			ObjRender_SetAngleZ(enm, startAng + 180);

			startAng += angChangeSpeed;

			yield;

		}

	}

	// space
	async{

		ascent(i in 0..spaceMovementTime){
			
			spaceX = FUNC_LERP_SMOOTH(startSpaceX, endSpaceX, i/spaceMovementTime);
			spaceY = FUNC_LERP_SMOOTH(startSpaceY, endSpaceY, i/spaceMovementTime);
			ObjRender_SetScaleXYZ(enm, FUNC_LERP_SMOOTH(startScale, endScale, i/spaceMovementTime));

			yield;
		}
		
	}

	// alpha
	async{

		ascent(i in 0..max(1, invinTime-10)){
			ObjRender_SetAlpha(enm, FUNC_LERP_SMOOTH(startAlpha, endAlpha, i/max(1, invinTime-10)));
			yield;
		}

	}

	// the enemy leaves

	async{

		ascent(i in 0..leaveTime){
			yield;
		}
		if(Obj_IsDeleted(enm)){return;}
		else{

			ascent(i in 0..120){
				
				spaceX = FUNC_LERP_SMOOTH(endSpaceX, STG_WIDTH * 4, i/120);
				spaceY = FUNC_LERP_SMOOTH(endSpaceY, STG_WIDTH * 4, i/120);

				yield;

			}

		}

	}

	return enm;

}

