function <int> _MinibossShip(
	int renderPriority, invinTime, lifeTime,
	float enmX, float enmY, int[] rectArray, float enemyHP
	){

	// Spawns enemy.

	int spd = 5;
	
	int enm = _CreateEnemy(
	enmX, enmY, 
	enmX, enmY, 
	5, 0.8, 0.8,
	enemyHP, largeEnemyHitbox * 1.1, 2,
	lifeTime,
	texEnm2,
	rectArray);
	
	ObjRender_SetTextureFilter(enm, FILTER_NONE, FILTER_NONE, FILTER_NONE);
	Obj_SetRenderPriorityI(enm, renderPriority);
	CreateEnemyLifebar(enm, enemyHP);

	int frame = 0;

	async{

		while(!Obj_IsDeleted(enm)){

			// Deadzone
			invinTime--;
			if(invinTime > 0){ObjEnemy_SetDamageRate(enm, 0.1, 0.1);}
			else{ObjEnemy_SetDamageRate(enm, 1, 1);}

			yield;

		}

	}

	LargeExplosion_Cancel(enm, 32, 8);

	_EnemyItemDrop(
		enm,
		medFlyingEnm_itemPointMin * 2, medFlyingEnm_itemPointMax * 2,
		largeEnemyHitbox
	);
	
	return enm;
	
}


task LargeExplosion(target, explosionSize, explosionTime){

	float enmX = 0, enmY = 0;

	while(ObjEnemy_GetInfo(target, INFO_LIFE) > 0){
		enmX = ObjMove_GetX(target);
		enmY = ObjMove_GetY(target);
		yield;
	}

	if(
		enmX < -16 || enmX > STG_WIDTH + 16
		|| enmY < -16 || enmY > STG_HEIGHT + 16
	)
	{return;}

	//DeleteShotAll(TYPE_ALL, TYPE_ITEM);
	
	ascent(i in 0..explosionTime){
		NotifyEvent(GetCommonDataPtr(SYSTEMID_PTR, "0"), EV_EXPLODE, [enmX + prand(-explosionSize, explosionSize), enmY + prand(-explosionSize, explosionSize)]);
		wait(4);
	}

	ascent(i in 0..20){
		NotifyEvent(GetCommonDataPtr(SYSTEMID_PTR, "0"), EV_EXPLODE, [enmX + prand(-explosionSize, explosionSize), enmY + prand(-explosionSize, explosionSize)]);
	}

	//ObjSound_Play(bossBoom);

}

task MediumExplosion_Cancel(target, explosionSize, explosionTime){

	float enmX = 0, enmY = 0;

	enmX = ObjMove_GetX(target);
	enmY = ObjMove_GetY(target);

	DeleteShotAll(TYPE_ALL, TYPE_ITEM);
	
	ascent(i in 0..explosionTime){
		NotifyEvent(GetCommonDataPtr(SYSTEMID_PTR, "0"), EV_EXPLODE, [enmX + prand(-explosionSize, explosionSize), enmY + prand(-explosionSize, explosionSize)]);
		ObjSound_Play(bossBoom);
		wait(4);
	}

	ascent(i in 0..30){
		NotifyEvent(GetCommonDataPtr(SYSTEMID_PTR, "0"), EV_EXPLODE, [enmX + prand(-explosionSize, explosionSize), enmY + prand(-explosionSize, explosionSize)]);
	}

	ObjSound_Play(bossBoom);

}

task LargeExplosion_Cancel(target, explosionSize, explosionTime){

	float enmX = 0, enmY = 0;

	while(ObjEnemy_GetInfo(target, INFO_LIFE) > 0){
		enmX = ObjMove_GetX(target);
		enmY = ObjMove_GetY(target);
		yield;
	}

	if(
		enmX < -24 || enmX > STG_WIDTH + 24
		|| enmY < -24 || enmY > STG_HEIGHT + 24
	)
	{return;}

	DeleteShotAll(TYPE_SHOT, TYPE_ITEM);
	
	ascent(i in 0..explosionTime){
		NotifyEvent(GetCommonDataPtr(SYSTEMID_PTR, "0"), EV_EXPLODE, [enmX + prand(-explosionSize, explosionSize), enmY + prand(-explosionSize, explosionSize)]);
		ObjSound_Play(bossBoom);
		wait(4);
	}

	ascent(i in 0..30){
		NotifyEvent(GetCommonDataPtr(SYSTEMID_PTR, "0"), EV_EXPLODE, [enmX + prand(-explosionSize, explosionSize), enmY + prand(-explosionSize, explosionSize)]);
	}

	ObjSound_Play(bossBoom);

}

task LargeExplosion_Cancel_Boss(pos, explosionSize, explosionTime){

	DeleteShotAll(TYPE_ALL, TYPE_ITEM);
	
	ascent(i in 0..explosionTime){
		NotifyEvent(GetCommonDataPtr(SYSTEMID_PTR, "0"), EV_EXPLODE, [pos[0] + prand(-explosionSize, explosionSize), pos[1] + prand(-explosionSize, explosionSize)]);
		ObjSound_Play(bossBoom);
		wait(4);
	}

	ascent(i in 0..30){
		NotifyEvent(GetCommonDataPtr(SYSTEMID_PTR, "0"), EV_EXPLODE, [pos[0] + prand(-explosionSize, explosionSize), pos[1] + prand(-explosionSize, explosionSize)]);
	}

	ObjSound_Play(bossBoom);

}

task _MiniRatePopup(float enmX, float enmY, float rate){

	float time = 30; // Time that the text objects (appear+)last on screen
	float timeDisappear = 15; // Fade time
	float size = 180 * clamp(rate/4, 0.25, 1);
	float yDes = 80; // Destination text object moves to, relative to enmY 
	string font = "TypeR";
	float borderSize = 8  * clamp(rate/4, 0.25, 1);

	int rateRounded = clamp(floor(rate), 1, 4);

	string textResult = "";

	if (GetCommonDataPtr(POINTER_BURSTMODE, false) == false){
		alternative(rateRounded)
		case(1){
			size = 50;
			yDes = 80;
			textResult = IntToString(rateRounded) ~ "[font sz=25 oy=25]x";
		}
		case(2){
			size = 70;
			yDes = 105;
			textResult = IntToString(rateRounded) ~ "[font sz=32 oy=30]x";
		}
		case(3){
			size = 80;
			yDes = 120;
			textResult = IntToString(rateRounded) ~ "[font sz=38 oy=40]x";
		}
		case(4){
			size = 150;
			yDes = 135;
			textResult = IntToString(rateRounded) ~ "[font sz=47 oy=70]x";
		}
	}

	else{

		alternative(rateRounded)
		case(1){
			size = 90;
			yDes = 80;
			textResult = IntToString(rateRounded*2) ~ "[font sz=42 oy=50]x";
		}
		case(2){
			size = 110;
			yDes = 105;
			textResult = IntToString(rateRounded*2) ~ "[font sz=50 oy=60]x";
		}
		case(3){
			size = 120;
			yDes = 120;
			textResult = IntToString(rateRounded*2) ~ "[font sz=62 oy=70]x";
		}
		case(4){
			size = 180;
			yDes = 135;
			textResult = IntToString(rateRounded*2) ~ "[font sz=69 oy=100]x";
		}

	}

	int pointText = CreateTextObject(
		enmX, enmY, size,
		textResult, font,
		0x7699FF, 0xFFFFFF,
		0x2A00C0, size/20,
		44
	);

	ObjText_SetSidePitch(pointText, 1);

	if (GetCommonDataPtr(POINTER_BURSTMODE, false) == true){

		ObjText_SetFontBorderColor(pointText, 0xFF581A);
		ObjText_SetFontColorTop(pointText, 0xFF9C30);

	}

	else{

		ObjText_SetFontBorderColor(pointText, 0x190371);
		ObjText_SetFontColorTop(pointText, 0x3071FF);

	}
	
	ObjText_SetFontBold(pointText, true);
	ObjText_SetHorizontalAlignment(pointText, ALIGNMENT_CENTER);
	
	async{
		if(rateRounded >= 4){
			
			if (GetCommonDataPtr(POINTER_BURSTMODE, false) == true && rateRounded == 4){

				ascent(i in 0..(time+timeDisappear)){

					if (i % 2 == 0){
						ObjText_SetFontBorderColor(pointText, 0xFFFC4D);
						ObjText_SetFontColorTop(pointText, 0xFFFC4D);
					}

					else{
						ObjText_SetFontBorderColor(pointText, 0xFF2700);
						ObjText_SetFontColorTop(pointText, 0xFF9C30);
					}

					yield;

				}

			}


			else if (GetCommonDataPtr(POINTER_BURSTMODE, false) == false && rateRounded == 4){

				ascent(i in 0..(time+timeDisappear)){

					if (i % 2 == 0){
						ObjText_SetFontBorderColor(pointText, 0x4DD7FF);
						ObjText_SetFontColorTop(pointText, 0x4DD7FF);
					}

					else{
						ObjText_SetFontBorderColor(pointText, 0x0012FF);
						ObjText_SetFontColorTop(pointText, 0x3071FF);
					}

					yield;

				}

			}

		}
	}

	ascent(i in 0..time){
		ObjRender_SetY(pointText, clamp(Interpolate_Decelerate(enmY, enmY-yDes, i/time), 0, STG_HEIGHT));
		yield;
	}

	ascent(i in 0..timeDisappear){
		ObjRender_SetY(pointText, clamp(ObjRender_GetY(pointText)-1, 0, STG_HEIGHT));
		ObjRender_SetAlpha(pointText, Interpolate_Decelerate(255, 0, i/timeDisappear));
		yield;
	}
	
	Obj_Delete(pointText);

}