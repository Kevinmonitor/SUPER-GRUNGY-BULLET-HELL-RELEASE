let texEnm = "script/StageData/StageLib/StageLib_Placeholder.png";
let texEnm2 = "script/StageData/StageLib/StageLib_Part2.png";
#include "./Stage_Values.dnh"

float deadZone = 16;

LoadTextureEx(texEnm, true, true);
