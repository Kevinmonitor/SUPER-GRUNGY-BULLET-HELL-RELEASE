	}

	LargeExplosion_Cancel(enm, 32, 8);

	_EnemyItemDrop(
		enm,
		medFlyingEnm_itemPointMin, medFlyingEnm_itemPointMax,
		medEnemyHitbox
	);
	
	return enm;
	
}

