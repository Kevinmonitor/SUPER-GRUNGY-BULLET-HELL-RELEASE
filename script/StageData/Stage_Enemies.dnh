// creating enemy lifebars

task CreateEnemyLifebar(int enm, float HP){

	float GAUGE_WIDTH = 30;
	float GAUGE_LENGTH = 224;

	float x, y;

	let objGaugeFill = CreateEffectObject(0, 0, texEnm, "NORMAL", 780, 80, 1012, 114);

	let objGauge = _Create2DImage(texEnm, [768, 0, 1024, 64]);
	//let objGaugeFill = _Create2DImage(texEnm, [768, 64, 1024, 128]);

	Obj_SetRenderPriorityI(objGauge, 52);
	Obj_SetRenderPriorityI(objGaugeFill, 51);

	ObjRender_SetScaleXYZ(objGauge, 0.5);
	ObjRender_SetScaleXYZ(objGaugeFill, 0.5);

	ObjRender_SetAlpha(objGauge, 180);
	ObjRender_SetAlpha(objGaugeFill, 255);

	while(ObjEnemy_GetInfo(enm, INFO_LIFE) > 0){

		x = XMove(enm); y = YMove(enm);

		ObjSprite2D_SetDestRect(objGaugeFill, 0, 0, ((ObjEnemy_GetInfo(enm, INFO_LIFE)/(HP)))*GAUGE_LENGTH, GAUGE_WIDTH);
		ObjRender_SetPosition(objGaugeFill, x - 56, y - 54, 0);
		ObjRender_SetPosition(objGauge, x, y - 48, 0);

		yield;

	}

	Obj_Delete(objGauge);
	Obj_Delete(objGaugeFill);

}

function <int> CreateUmbrellaEnemy(
	int renderPriority, int[] rect,
	float enmX, enmY, scale, hitbox,
	int invinTime, int killTime, int enmHealth, int itemDropPoint, int itemDropChain
	){
	
	// Spawns enemy.
	
	int enm = _CreateEnemy(
	enmX, enmY, enmX, enmY, 5,
	scale, scale,
	enmHealth, hitbox, 0,
	texEnm,
	rect[0], rect[1], rect[2], rect[3]);
	
	Obj_SetRenderPriorityI(enm, renderPriority);
	
	async{
		while(!Obj_IsDeleted(enm)){
			ObjRender_SetAngleZ(enm, ObjRender_GetAngleZ(enm)+1.5);
			yield;
		}
	}
	
	async{
	
		ObjEnemy_SetDamageRate(enm, 0, 0);
		
		wait(invinTime);
		
		ObjEnemy_SetAutoDelete(enm, true);
	
	}
	
	_EnemyItemDrop(
	enm, true,
	itemDropPoint, itemDropChain,
	itemDropPoint*2+(GetCommonDataPtr(POINTER_RANK, 1)-1)*2, itemDropChain*2+(GetCommonDataPtr(POINTER_RANK, 1)-1)*2, 
	killTime, hitbox*2.5
	);
	
	return enm;

}

function <int> _Missile(
	int renderPriority, invinTime,
	float enmX, float enmY, int[] rectArray
	){

	// Spawns enemy.

	int spd = 5;
	
	int enm = _CreateEnemy(
	enmX, enmY, 
	enmX, enmY, 
	5, 0.75, 0.75,
	popcornHP, popcornHitbox, 0,
	texEnm,
	rectArray);
	
	ObjRender_SetTextureFilter(enm, FILTER_NONE, FILTER_NONE, FILTER_NONE);
	Obj_SetRenderPriorityI(enm, renderPriority);

	int frame = 0;

	async{

		while(!Obj_IsDeleted(enm)){

			// Deadzone
			invinTime--;
			if(invinTime > 0){ObjEnemy_SetDamageRate(enm, 0, 0);}
			else{ObjEnemy_SetDamageRate(enm, 1, 1);}

			yield;

		}

	}

	_EnemyItemDrop(
		enm,
		smallFlyingEnm_itemPointMin * 0.5, smallFlyingEnm_itemPointMax * 0.5,
		popcornHitbox
	);
	
	return enm;
	
}

