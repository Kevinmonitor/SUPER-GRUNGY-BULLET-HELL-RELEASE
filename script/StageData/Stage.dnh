task THiScore(){
 	// New score system using rtos

 	// For score with zeroes at the end: Truncate score/10, and then multiply it by 10

	if(IsReplay() || LifeStart > 2){return;}

	let objScoreNo = ObjText_Create();
	ObjText_SetFontSize(objScoreNo, 30);
	ObjText_SetFontBold(objScoreNo, false);
	ObjText_SetFontType(objScoreNo, "Bedstead");
	ObjText_SetFontColorTop(objScoreNo, 0xFFFFFF);
	ObjText_SetFontColorBottom(objScoreNo, 0xFFFFFF);
	Obj_SetRenderPriorityI(objScoreNo, 82);
	ObjText_SetSidePitch(objScoreNo, 4);
	ObjText_SetFixedWidth(objScoreNo, 16);
	ObjRender_SetPosition(objScoreNo, 963, 329, 0);

	while(true){

		let score = trunc(hiScore/10) * 10;
		score = min(score,999999999990);

		if(hiScore < GetScore()){
			hiScore = GetScore();
		}

		let yass = DigitToCommaArray(score);
		ObjText_SetText(objScoreNo, yass);
		
		yield;

	}

}

task TDiffShow(){
 	// New score system using rtos

 	// For score with zeroes at the end: Truncate score/10, and then multiply it by 10

	int color = [0xD67600, 0x36DC00, 0x0071DB, 0xDB0070, 0xA800DB][GetAreaCommonData("Ingame", "DifficultyNo", 0)];

	let objScoreNo = ObjText_Create();
	ObjText_SetFontSize(objScoreNo, 24);
	ObjText_SetFontBold(objScoreNo, true);
	ObjText_SetFontType(objScoreNo, "Bedstead");
	ObjText_SetFontColorTop(objScoreNo, 0xFFFFFF);
	ObjText_SetFontColorBottom(objScoreNo, 0xFFFFFF);
	ObjText_SetFontBorderColor(objScoreNo, color);
	ObjText_SetFontBorderWidth(objScoreNo, 2);
	ObjText_SetFontBorderType(objScoreNo, BORDER_FULL);
	Obj_SetRenderPriorityI(objScoreNo, 82);
	//ObjText_SetSidePitch(objScoreNo, 2);
	ObjRender_SetPosition(objScoreNo, 963, 672, 0);
	ObjText_SetText(objScoreNo, DifficultyName[GetAreaCommonData("Ingame", "DifficultyNo", 0)]);

}

task CheckPlayerDeath(){

    while(GetPlayerState() != STATE_END){yield;}

	if(GetPlayerState() == STATE_END){
		NotifyEventAll(EV_END, true);
		loop(120){yield;}
		//ステージ終了
		CloseStgScene();
	}

}

function TStageSection(){

	async{

		while(GetPlayerState() != STATE_END)
		{
			yield;
		}

		EndBonus();

		NotifyEventAll(EV_END, true);
		loop(120){yield;}
		//ステージ終了
		CloseStgScene();

	}

	let midboss = LoadScriptInThread("script/BossData/Midboss/mboss_plural.dnh");
	//while(GetScriptStatus(midboss) != STATUS_LOADED){yield;} // DO NOT DO THIS OR YOUR REPLAY WILL SHIT ITSELF

	StartStageTimer();

	//Stage tasks here

	Chapter1A();
	Chapter1B();
	Chapter1C();

	// pre-midboss

	// ObjSound_Seek(objBGM, 51.455);
	Chapter1D();
	wait(60);

	// Midboss start: 0:58 -> 1:26 -> ~28 seconds

	SetCommonData("midbossKillTime", 0); // in frames

	StartScript(midboss);

    while(!IsCloseScript(midboss) && GetPlayerState() != STATE_END)
    {
        yield;
    }

	// why do i have to do this?
	
	_CreateBulletColourShader();
	Chapter1Bonus(); // bonus enemies
	
}

function TStageSectionPart2(){

	//Stage continue

	//SetIntersectionVisualization(true);

	//ObjSound_Seek(objBGM, 80.720);

	Chapter2Zero();

	postMidbossBGStart = true;
	
	Chapter2A();
	Chapter2B();

	// wait(240);
	Chapter2C();
	Chapter2D();

}

function TBossSection(){

	let boss = LoadScriptInThread("script/BossData/Boss/boss_plural.dnh");

	//Boss start
	NotifyEvent(GetOwnScriptID(), EV_FADE_STAGE_MUSIC, true);
	wait(45);

	postMidbossBGStart = true;
	wait(45);
	
	BossWarning();

	while(!bossRoomTransitionBGStart){yield;}

	NotifyEvent(GetOwnScriptID(), EV_BOSS_MUSIC_START, true);

	// transition

	BossIntroA();

	while(!bossRoomTransitionBGMiddle){yield;}

	NotifyEvent(GetOwnScriptID(), EV_BOSS_MUSIC_MIDDLE, true);

	BossIntroB();

	NotifyEvent(GetOwnScriptID(), EV_BOSS_START, true);
	StartScript(boss);
	_bossArena();
	
	// //EndScreen();
	
    while(!IsCloseScript(boss))
    {
        yield;
    }

	// EndBonus();

	NotifyEventAll(EV_END_PHASE_1, true);
    loop(30){yield;}

    // CloseStgScene();

}

