task StartStageTimer(){

	let objScoreNo = ObjText_Create();
	ObjText_SetFontSize(objScoreNo, 24);
	ObjText_SetFontBold(objScoreNo, true);
	ObjText_SetFontType(objScoreNo, "Bedstead");
	ObjText_SetFontColorTop(objScoreNo, 0xFFE698);
	ObjText_SetFontColorBottom(objScoreNo, 0xFFE698);
	Obj_SetRenderPriorityI(objScoreNo, 82);
	ObjText_SetSidePitch(objScoreNo, 1);
	ObjText_SetFixedWidth(objScoreNo, 12);
	ObjRender_SetPosition(objScoreNo, 64, 48, 0);
    ObjText_SetHorizontalAlignment(objScoreNo, ALIGNMENT_LEFT);

	int frame = 0;
	ObjText_SetText(objScoreNo, "");

	while(true){

		// frame++;
		// ObjText_SetText(objScoreNo, "stage frame " ~ ToString(frame));
		
		yield;
        
	}

}

function SaveHiScore(){

	if(!IsReplay() & LifeStart <= 2){
		
		if(hiScore > GetAreaCommonData("Data_" ~ PlayerName[GetAreaCommonData("Ingame", "PlayerNum")], 
			"HighScore_" ~ GameMode[GetAreaCommonData("Ingame", "GameMode")] ~ "_" ~ DifficultyName[GetAreaCommonData("Ingame", "DifficultyNo")], 0))
		{
			SetAreaCommonData("Data_" ~ PlayerName[GetAreaCommonData("Ingame", "PlayerNum")], 
			"HighScore_" ~ GameMode[GetAreaCommonData("Ingame", "GameMode")] ~ "_" ~ DifficultyName[GetAreaCommonData("Ingame", "DifficultyNo")], 
			hiScore);
		}

		else{

		}
	
	}

	SaveCommonDataAreaA2("Data_" ~ PlayerName[GetAreaCommonData("Ingame", "PlayerNum")], "script/SaveData/data_" ~ PlayerName[GetAreaCommonData("Ingame", "PlayerNum")] ~ ".dat");

}

function EndBonus(){


	string[] summaryTexts = [

		"CHARACTER: ",
		"DIFFICULTY: ",
		"HITS TAKEN: ",
		"BURSTS USED: ",
		"DESTRUCTION RATE: "

	];

	string[] dataTexts = [

		PlayerName[GetAreaCommonData("Ingame", "PlayerNum")],
		DifficultyName[GetAreaCommonData("Ingame", "DifficultyNo")],
		IntToString(GetAreaCommonData("Ingame", "Deaths", 0)),
		IntToString(GetAreaCommonData("Ingame", "Bursts", 0)),
		vtos("3.02f", GetAreaCommonData("Ingame", "TotalDefeat", 1)/GetAreaCommonData("Ingame", "TotalEnemies", 1)*100) ~ "%"

	];

	int[] textColours = [

		0x700ADC,
		0x1300DD,
		0xFF3D3D,
		0x22D99B,
		0xFE7418

	];

	function <void> _CreateBonusText(float x, y, fontSize, int colorBorder, string text, bool isBold, const alignment){
	
		int objText = CreateTextObject(
		
		x, y, fontSize,
		"", "Aquire",
		0xFFFFFF, 0xFFFFFF,
		colorBorder, fontSize/12,
		71
		
		);
		
		ObjText_SetHorizontalAlignment(objText, alignment);
		ObjText_SetFontBold(objText, isBold);
		//ObjText_SetSidePitch(objText, 4);
		
		ObjText_SetText(objText, text);
		TTextScroll(objText, text);
		
	}
    
    if(GetPlayerLife() < 0){
		SetCommonData("Player State", "GAMEOVER");
        _CreateBonusText(STG_WIDTH/2, STG_HEIGHT/2-96, 64, 0xDD2727, "GAME OVER", false, ALIGNMENT_CENTER);
    }

    else{

		SetCommonData("Player State", "GAMECLEAR");
		GrantDifficultyAchievements();
		GrantCharacterAchievements();

		ascent(i in 0..length(summaryTexts)){

			_CreateBonusText(STG_WIDTH/2 - 240, STG_HEIGHT/5 + 36*i, 26, textColours[i], summaryTexts[i], true, ALIGNMENT_LEFT);
			wait(20);
			_CreateBonusText(STG_WIDTH/2 + 240, STG_HEIGHT/5 + 36*i, 26, textColours[i], dataTexts[i], false, ALIGNMENT_RIGHT);
			wait(20);

		}

		wait(60);

		if(IsReplay()){
			_CreateBonusText(STG_WIDTH/2, STG_HEIGHT/2, 32, 0xFFA300, "REPLAY COMPLETE", true, ALIGNMENT_CENTER);
		}	
		else{
			_CreateBonusText(STG_WIDTH/2, STG_HEIGHT/2, 32, 0xFFA300, "THANK YOU FOR PLAYING!", true, ALIGNMENT_CENTER);
		}

    }

	wait(60);

	int fade = _Create2DImage("script/PackageContent/FadeToWhite.png", [0, 0, 1280, 720]);
	ObjRender_SetPosition(fade, GetScreenWidth()/2, GetScreenHeight()/2, 1);
	Obj_SetRenderPriorityI(fade, 100);
	ObjRender_SetAlpha(fade, 0);

	ascent(i in 0..150){
		ObjRender_SetAlpha(fade, FUNC_LERP_DECEL(0, 255, i/150));
		yield;
	}

    return;
	
}




////

//// ACHIEVEMENT GRANTING 

////






task CheckScoringAchievements(){
	
	if(IsReplay() || LifeStart > 2){return;}

	async{
		while(GetPlayerState() != STATE_END){yield;}
		return;
	}

	while(GetScore() <= 20000000000){yield;}
	NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 4, 16);

	while(GetScore() <= 50000000000){yield;}
	NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 5, 15);

	while(GetScore() <= 100000000000){yield;}
	NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 6, 16);

	while(GetScore() <= 200000000000){yield;}
	NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 7, 16);

}

task GrantDifficultyAchievements(){
	
	if(IsReplay() || LifeStart > 2){return;}

	if(GetAreaCommonData("Ingame", "DifficultyNo", 0) >= 3){
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 3, 16);
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 2, 16);
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 1, 16);
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 0, 16);
	}
	else if (GetAreaCommonData("Ingame", "DifficultyNo", 0) >= 2){
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 2, 16);
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 1, 16);
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 0, 16);
	}
	else if (GetAreaCommonData("Ingame", "DifficultyNo", 0) >= 1){
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 1, 16);
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 0, 16);
	}
	else{
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 0, 16);
	}

}

task GrantCharacterAchievements(){
	
	if(IsReplay() || LifeStart > 2){return;}

	// Lavender
	if(
		GetAreaCommonData("Ingame", "DifficultyNo", 0) >= 1 &&
		GetAreaCommonData("Ingame", "PlayerNum", 0) == 1 &&
		GetAreaCommonData("Ingame", "Bursts", 0) >= 100
	)
	{
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 8, 15);
	}

	// Kobiko
	if(
		GetAreaCommonData("Ingame", "DifficultyNo", 0) >= 1 &&
		GetAreaCommonData("Ingame", "PlayerNum", 0) == 2 &&
		(GetCommonDataPtr(POINTER_ENEMYKILLED, 1)/GetCommonDataPtr(POINTER_ENEMYCOUNT, 1)) >= 0.9799
	)
	{
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 9, 14);
	}

	// Penmaster
	if(
		GetAreaCommonData("Ingame", "DifficultyNo", 0) >= 2 &&
		GetAreaCommonData("Ingame", "PlayerNum", 0) == 0 &&
		GetAreaCommonData("Ingame", "Deaths", 0) <= 0
	)
	{
		NotifyEventAll(EV_UNLOCK_ACHIEVEMENT, 10, 17);
	}


}