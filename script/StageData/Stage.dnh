int LifeStart = GetCommonData("Starting Lives", 2);
int curDiff = 1;
int curRank = 0;
float curRankSpeed = 1.0;

bool stageStart = false;
bool bossStart = false;

float BGMRate = GetAreaCommonData("Config", "BGMVol", 100) * 0.01;

//let obj = ObjEnemyBossScene_Create();
int objBGM = ObjSound_Create();
int objBGMBoss = ObjSound_Create();
int objBGMBossPart1 = ObjSound_Create();
int objBGMBossPart2 = ObjSound_Create();

int objBGMBossPhase2Part1 = ObjSound_Create();
int objBGMBossPhase2Part2 = ObjSound_Create();

int currentlyPlayingBGM = ObjSound_Create();

string DATA_PLAYER = "";
string DATA_DIFFICULTY = "";

bool bossRoomBGStart = false;
bool bossRoomTransitionBGStart = false;
bool bossRoomTransitionBGMiddle = false;
bool bossBGStart = false;

bool postMidbossBGStart = false;

bool phase2BGStart = false;

int hiScore = 0;

@Initialize
{

	SetCommonDataPtr(POINTER_ENEMYCOUNT, 1);
	SetCommonDataPtr(POINTER_ENEMYKILLED, 1);
	SetCommonDataPtr(POINTER_BURSTCOUNT, 0);
	SetCommonDataPtr(POINTER_DEATHCOUNT, 0);

	LoadTextureEx("script/BossData/Boss/bossSplash.png", false, true);
	LoadTextureEx("script/BossData/Midboss/midbossSplash.png", false, true);
	
	SetCommonData("Player State", "GAMENORMAL");
	SetCommonData("True Score", 0);
	SetCommonData("BurstAllowed", true);
	
	SetAreaCommonData("ScriptID", "StageID", GetOwnScriptID());

    SetPlayerLife(GetAreaCommonData("Config", "StartingLife", 2));
	SetEnemyAutoDeleteClip(48, 48, 48, 48);

	LoadTracks();

	//SetAreaCommonData("Ingame", "Difficulty", "Original");
	curDiff = _InitDifficulty();
	ManageRankLimits(curDiff, true);
	curRankSpeed = RankSpeed[curDiff];

	SetAreaCommonData("Ingame", "DifficultyNo", curDiff);
	
	hiScore = GetAreaCommonData("Data_" ~ PlayerName[GetAreaCommonData("Ingame", "PlayerNum")], "HighScore_" ~ GameMode[GetAreaCommonData("Ingame", "GameMode")] ~ "_" ~ DifficultyName[GetAreaCommonData("Ingame", "DifficultyNo")], 0);

	THiScore;
	TDiffShow();
	_CreateBulletColourShader();
	
	WriteLog(PlayerName[GetAreaCommonData("Ingame", "PlayerNum")]);
	WriteLog(GameMode[GetAreaCommonData("Ingame", "GameMode")]);
	WriteLog(DifficultyName[GetAreaCommonData("Ingame", "DifficultyNo")]);

	WriteLog(GetAreaCommonData("Ingame", "PlayerNum"));
	WriteLog(GetAreaCommonData("Ingame", "DifficultyNo"));

	CheckScoringAchievements();
   	TStage();
	//TTest();
}

@Event{

	alternative (GetEventType())



	// MUSIC AND TRANSITION-RELATED EVENTS




	case(EV_START_MUSIC){
		stageStart = true;
		ObjSound_Play(objBGM);
		currentlyPlayingBGM = objBGM;
	}

    case(EV_FADE_STAGE_MUSIC){
		ObjSound_SetFade(objBGM, -50);
    }
    
    case(EV_FADE_BOSS_MUSIC){
		ObjSound_SetFade(objBGMBoss, -50);
    }

	case(EV_BOSS_MUSIC_START){

		ObjSound_Play(objBGMBossPart1);
		currentlyPlayingBGM = objBGMBossPart1;
		_bossRoomTransition();

	}

	case(EV_BOSS_MUSIC_MIDDLE){

		ObjSound_Play(objBGMBossPart2);
		currentlyPlayingBGM = objBGMBossPart2;
		_bossArenaPreparation();

	}

	case(EV_BOSS_START){

		ObjSound_Play(objBGMBoss);
		ObjSound_Seek(objBGMBoss, 35.127); // lets go!
		
		currentlyPlayingBGM = objBGMBoss;
		bossBGStart = true;

	}

	case(EV_PAUSE_ENTER){

		ObjSound_Stop(currentlyPlayingBGM);

	}

	case(EV_PAUSE_LEAVE){

		ObjSound_Play(currentlyPlayingBGM);

	}

	case(EV_APP_LOSE_FOCUS){
		NotifyEventAll(EV_PAUSE_ENTER);
	}

	case(EV_END_PHASE_1){
		bossStart = false;
		stageStart = false;
		ObjSound_SetFade(objBGM, -50);
		ObjSound_SetFade(objBGMBoss, -50);
		// SetCommonData("True Score", trunc ( GetScore()/10 ) * 10 );
		// SaveHiScore();
	}

	case(EV_START_PHASE_2){
		
		phase2BGStart = true;
		
		STG_WIDTH = GetStgFrameWidth();
		STG_HEIGHT = GetStgFrameHeight();

		ObjSound_Play(objBGMBossPhase2Part1);
		// ObjSound_Seek(objBGMBoss, 35.127); // lets go!
		
		currentlyPlayingBGM = objBGMBossPhase2Part1;

	}

	case(EV_BOSS_PHASE_2_MUSIC_START){
		
		STG_WIDTH = GetStgFrameWidth();
		STG_HEIGHT = GetStgFrameHeight();

		ObjSound_Seek(objBGMBossPhase2Part2, 45.880); // lets go!
		ObjSound_Play(objBGMBossPhase2Part2);
		
		currentlyPlayingBGM = objBGMBossPhase2Part2;

	}




	// THINGS WHICH ARE NOT MUSIC




	case(EV_BOSS_SUMMON_BACKUP){

		alternative(GetEventArgument(0))
		case(1){
			Backup1();
		}
		case(2){
			Backup2();
		}
		case(3){
			Backup3();
			NotifyEventOwn(EV_END_PHASE_1B, 0);
		}
		case(4){
			Backup4();
		}

	}

	case(EV_FADE_NORMAL_BG){
		bossRoomBGStart = true;
	}

	case(EV_BOSS_ATTACK_CLEAR)
	{
		
		float[] pos = GetEventArgument(0);
		
		LargeExplosion_Cancel_Boss(pos, 180, 15);

	}

	case(EV_PLAYER_SHOOTDOWN){
		SetCommonDataPtr(POINTER_DEATHCOUNT, GetCommonDataPtr(POINTER_DEATHCOUNT, 0)+1);
	}

	case(EV_USER_BURST){
		SetCommonDataPtr(POINTER_BURSTCOUNT, GetCommonDataPtr(POINTER_BURSTCOUNT, 0)+1);
	}

	case(EV_END_PHASE_1A){
		endPhase1A();
	}
	
	case(EV_END_PHASE_1B){
		endPhase1B();
	}

}

@MainLoop
{

	curRank = GetCommonDataPtr(POINTER_RANK, 1);
	SetCommonDataPtr(POINTER_TRUERANK, GetCommonDataPtr(POINTER_TRUERANK, 1)+0.006*curRankSpeed);
    yield;

}

@Finalize
{
}

function LoadTracks(){

    ObjSound_Load(objBGM, "script/StageData/StageLib/stageMusic/stg_theme_full.ogg");
	ObjSound_SetSoundDivision(objBGM, SOUND_BGM);
	ObjSound_SetResumeEnable(objBGM, true);
	ObjSound_SetLoopEnable(objBGM, true);
	ObjSound_SetLoopTime(objBGM, 1.512, 141.670);
	
	ObjSound_Load(objBGMBoss, "script/StageData/StageLib/stageMusic/bossThemeFull.ogg");
	ObjSound_SetSoundDivision(objBGMBoss, SOUND_BGM);
	ObjSound_SetResumeEnable(objBGMBoss, true);
	ObjSound_SetLoopEnable(objBGMBoss, true);

	ObjSound_Load(objBGMBossPart1, "script/StageData/StageLib/stageMusic/bossThemePart1.ogg");
	ObjSound_SetSoundDivision(objBGMBossPart1, SOUND_BGM);
	ObjSound_SetResumeEnable(objBGMBossPart1, true);
	ObjSound_SetLoopEnable(objBGMBossPart1, false);

	ObjSound_Load(objBGMBossPart2, "script/StageData/StageLib/stageMusic/bossThemePart2.ogg");
	ObjSound_SetSoundDivision(objBGMBossPart2, SOUND_BGM);
	ObjSound_SetResumeEnable(objBGMBossPart2, true);
	ObjSound_SetLoopEnable(objBGMBossPart2, false);
	
	ObjSound_SetVolumeRate(objBGMBoss, 50*BGMRate);
	ObjSound_SetVolumeRate(objBGMBossPart1, 50*BGMRate);
	ObjSound_SetVolumeRate(objBGMBossPart2, 50*BGMRate);
	ObjSound_SetVolumeRate(objBGM, 75*BGMRate);

	ObjSound_Load(objBGMBossPhase2Part1, "script/StageData/StageLib/stageMusic/bossTrueForm_01.ogg");
	ObjSound_SetSoundDivision(objBGMBossPhase2Part1, SOUND_BGM);
	ObjSound_SetResumeEnable(objBGMBossPhase2Part1, true);
	ObjSound_SetLoopEnable(objBGMBossPhase2Part1, false);

	ObjSound_SetVolumeRate(objBGMBossPhase2Part1, 70*BGMRate);

	ObjSound_Load(objBGMBossPhase2Part2, "script/StageData/StageLib/stageMusic/bossTrueForm_02.ogg");
	ObjSound_SetSoundDivision(objBGMBossPhase2Part2, SOUND_BGM);
	ObjSound_SetResumeEnable(objBGMBossPhase2Part2, true);
	ObjSound_SetLoopEnable(objBGMBossPhase2Part2, false);

	ObjSound_SetVolumeRate(objBGMBossPhase2Part2, 70*BGMRate);
	
	
}

