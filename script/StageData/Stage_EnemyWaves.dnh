				max(6.5, FUNC_LERP_SMOOTH(9.0, 6.5, rank/350)), 
				7 * (1.001 ^ rank), 7 * (1.001 ^ rank) * 0.95, max(7, FUNC_LERP_SMOOTH(12, 7, rank/350)),
