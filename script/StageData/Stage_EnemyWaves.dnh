			wait(frameMove);
			ObjEnemy_SetAutoDelete(ship, true);
			NewSpawnSpiral(
				ship,
				[1, 2, 3][min(2, floor(rank/120))], min(7, FUNC_LERP_SMOOTH(3, 7, rank/350)),
				max(6.5, FUNC_LERP_SMOOTH(9.0, 6.5, rank/350)), 
				6 * (1.002 ^ rank), 6 * (1.002 ^ rank) * 0.9, max(5, FUNC_LERP_SMOOTH(10, 5, rank/350)),
				KEV_BULLET, HUE_CYAN, 1.5,
				GetAngleToPlayer(ship), spinDir
			);
			wait(frameMove * 2);
