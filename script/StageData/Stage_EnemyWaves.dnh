			ObjEnemy_SetAutoDelete(ship, true);
			NewSpawnSpiral(
				ship,
				[2, 2, 3][min(2, floor(rank/100))], min(14, FUNC_LERP_SMOOTH(6, 14, rank/400)),
				max(6.5, FUNC_LERP_SMOOTH(10.5, 6.5, rank/350)), 
				5 * (1.001 ^ rank), 5 * (1.001 ^ rank) * 0.7, max(6, FUNC_LERP_SMOOTH(10, 6, rank/350)),
				KEV_BULLET, HUE_CYAN, 1.5,
				GetAngleToPlayer(ship), spinDir
			);
			wait(frameMove * 2);
			ObjMove_SetDestAtFrame(ship, leaveX, leaveY, frameMove * 4, LERP_ACCELERATE);
		}

		return ship;

	}

