		MediumEnemyB(x, -128, x, rand(STG_HEIGHT/7, 2.4 * STG_HEIGHT/5) + rand(-16, 16), x, rand(STG_HEIGHT + 150, STG_HEIGHT + 200), 45, [1, -1][rand_int(0, 1)], curRank);
	}

	wait(60);

	ascent(i in 0..3){
		float x = FUNC_LERP_SMOOTH(3 * STG_HEIGHT/7 + 24, 1 * STG_WIDTH/7 - 24, i/3) + rand(7, -7);
		MediumEnemyB(x, -128, x, rand(STG_HEIGHT/7, 2.4 * STG_HEIGHT/5) + rand(-16, 16), x, rand(STG_HEIGHT + 150, STG_HEIGHT + 200), 45, [1, -1][rand_int(0, 1)], curRank);
	}
	
	wait(15);

}

