			ObjMove_SetDestAtFrame(ship, leaveX, leaveY, frameMove * 4, LERP_ACCELERATE);
		}

		return ship;

	}

	function <int> AimedEnemy(rect, bulletHue, startX, startY, mainX, mainY, targetX, targetY, frameMove, zAngle, rank){

		int ship = _SmallShip(
			42, frameMove,
			startX, startY, rect
		);

		ObjRender_SetAngleZ(ship, zAngle);

		async{
			ObjMove_SetDestAtFrame(ship, mainX, mainY, frameMove, LERP_DECELERATE);
			wait(frameMove);
			FireTask();
			wait(frameMove * 2);
			ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove * 4, LERP_ACCELERATE);
		}

		task FireTask(){

			int bulletDel = max(20, FUNC_LERP_LINEAR(50, 20, rank/400));
			int bulletDense = [1, 3, 5][min(2, floor(rank/80))];
			float bulletAng = [0, 1.2, 1.4, 1.6, 2.0][min(4, floor(rank/60))];
			float bulletSpeed = 7.0 * (1.0009 ^ rank);

			while(!Obj_IsDeleted(ship)){
				NewCreateFan (ship, bulletDense, KEV_BULLET, bulletHue, 1, 
				0, bulletAng, bulletSpeed, 1, 1.5,
				PATTERN_FAN_AIMED, false);
				Shoot2;
				wait(bulletDel);
				yield;
			}

			return;
		}

		return ship;

	}

	ascent(i in 0..3){
		
		ascent(f in 0..3){

			float x = 1 * STG_WIDTH/6 + f * 64;
			AimedEnemy(
				smallshipRectC, HUE_RED,
				x, -48, 
				x, STG_HEIGHT/8 + f * 24 + i * 75, 
				x, STG_HEIGHT+96, 
				15, 180, curRank
			);

		}

		wait(9);
	}

	ascent(i in 0..3){
		
		ascent(f in 0..3){

			float x = 5 * STG_WIDTH/6 - f * 64;
			AimedEnemy(
				smallshipRectC, HUE_RED,
				x, -48, 
				x, STG_HEIGHT/8 + f * 24 + i * 75, 
				x, STG_HEIGHT+96, 
				15, 180, curRank
			);

		}

		wait(9);

	}

	ascent(i in 0..8){

		float x = FUNC_LERP_LINEAR(2*STG_WIDTH/12, 11*STG_WIDTH/12, i/8);
		AimedEnemy(
			smallshipRectB, HUE_CYAN,
			x, -48, 
			x, STG_HEIGHT/2, 
			x, STG_HEIGHT+96, 
			15, 180, curRank
		);

	}

	wait(60);

	ascent(i in 0..6){

		ascent(f in 0..2){

			ascent(g in 0..2){

				float x = [STG_WIDTH/10 + f * 72, 9 * STG_WIDTH/10 - f * 72][i % 2 == 0 ? 0 : 1];
				float y = 32 + (g * (STG_HEIGHT/18+16)) + (3 * i * STG_HEIGHT/18);
			
				AimedEnemy(
					smallshipRectB, HUE_CYAN,
					[-48, STG_WIDTH + 48][i % 2 == 0 ? 0 : 1], y, 
					x, y, 
					[STG_WIDTH + 96, -96][i % 2 == 0 ? 0 : 1], y, 
					15, [90, 270][i % 2 == 0 ? 0 : 1], curRank * 0.75
				);

			}

		}

		wait(9);

	}

	wait(60);

	async{

		ascent(i in 0..3){
			ascent(f in 0..3){
				LaserSFX;
				float x = STG_WIDTH/9 + f * 75;
				float y = STG_HEIGHT/7 + i * 72 + f * 36;
				_CreateWarningSign(x, y, 90 - (i * 3 + f * 3), 0.6);
				wait(3);
			}
		}

		wait(8);

		ascent(i in 0..3){
			ascent(f in 0..3){
				float x = STG_WIDTH/9 + f * 75;
				float y = STG_HEIGHT/7 + i * 72 + f * 36;
				AimedEnemy(smallshipRectC, HUE_RED, x, -48, x, y, x, STG_HEIGHT + 96, 12, 180, curRank);
				wait(3);
			}
		}

	}

	wait(32);

	async{

		ascent(i in 0..3){
			ascent(f in 0..3){
				LaserSFX;
				float x = 8 * STG_WIDTH/9 - f * 75;
				float y = 6.4 * STG_HEIGHT/7 - i * 72 - f * 36;
				_CreateWarningSign(x, y, 90 - (i * 3 + f * 3), 0.6);
				wait(3);
			}
		}

		wait(8);

		ascent(i in 0..3){
			ascent(f in 0..3){
				float x = 8 * STG_WIDTH/9 - f * 75;
				float y = 6.4 * STG_HEIGHT/7 - i * 72 - f * 36;
				AimedEnemy(smallshipRectC, HUE_RED, x, STG_HEIGHT + 48, x, y, x, -96, 12, 0, curRank);
				wait(3);
			}
		}

	}

	wait(96);
	
	ascent(i in 0..2){
		MediumEnemyA(medshipRectA, HUE_CYAN, 3*STG_WIDTH/4 + 140 - 84 * i, -48, 6, 96, 96+90, curRank);	
	}

	ascent(i in 0..2){
		MediumEnemyA(medshipRectC, HUE_RED, 1*STG_WIDTH/4 - 140 + 84 * i, STG_HEIGHT+48, 6, 96+180, 96+90+180, curRank);	
	}

	wait(96);

	LargeEnemyA(STG_WIDTH/4, -64, STG_WIDTH/4, STG_HEIGHT/4, STG_WIDTH/4, STG_HEIGHT+128, 20, -1, curRank);

	wait(70);

	ascent(i in 0..20){
		PopcornC(rand(STG_WIDTH/2-64, 3 * STG_WIDTH/4+64), 90 + rand(-3, 3), curRank);
		wait(2);
	}

	wait(30);

	ascent(i in 0..5){
		MediumEnemyB(medshipRectA, HUE_CYAN, 3*STG_WIDTH/4 - 160 + 54 * i, [-128, -96, -64, -96, -128][i], 8, 90, curRank);
	}

	wait(70);

	ascent(i in 0..4){
		ascent(f in 0..4){
			float x = STG_WIDTH/9 + f * 54;
			float y = STG_HEIGHT/5 + i * 72 + f * 36;
			AimedEnemy(smallshipRectC, HUE_RED, x, -48, x, y, x, STG_HEIGHT + 96, 12, 180, curRank);
			wait(2);
		}
	}
	
	wait(30);

	LargeEnemyB(STG_WIDTH/2, -64, STG_WIDTH/2, STG_HEIGHT/4, STG_WIDTH/2, STG_HEIGHT+128, 45, [-1, 1][rand_int(0, 1)], curRank, 1200);

	wait(30);

	ascent(i in 0..12){
		float x = [rand(STG_WIDTH/6 - 64, STG_WIDTH/6 + 64), rand(5 * STG_WIDTH/6 - 64, 5 * STG_WIDTH/6 + 64)][i % 2 == 0 ? 0 : 1];
		AimedEnemy(
			[smallshipRectA, smallshipRectC][i % 2 == 0 ? 1 : 0], 
			[HUE_CYAN, HUE_RED][i % 2 == 0 ? 1 : 0], 
			x, -64, 
			x, STG_HEIGHT/4, 
			x, STG_HEIGHT + 96, 
			15, 180, 
			curRank
		);
		wait(3);
	}

	wait(60);

	task CreateBossObject(){

		ObjRender_SetScaleXYZ(texBoss, 0.375);
		ObjRender_SetTextureFilterMin(texBoss, FILTER_LINEAR);
		Obj_SetRenderPriorityI(texBoss, 41);

		_EnemyRenderIdle(texBoss, 5, 0, 540, 720, 540, 6);

	}

	CreateBossObject();

	ascent(i in 0..48){

		ObjRender_SetPosition(texBoss, STG_WIDTH/2, FUNC_LERP_DECEL(STG_HEIGHT+128, STG_HEIGHT/2, i/48), 1);
		ObjRender_SetAlpha(texBoss, FUNC_LERP_LINEAR(0, 255, i/48));
		yield;

	}

	wait(12);

	ObjRender_SetAlpha(texBoss, 0);

}