	function <int> LargeEnemyC(enmX, enmY, targetX, targetY, leaveX, leaveY, frameMove, startAng, spinDir, rank){

		int ship = _LargeShip(
			42, frameMove,
			enmX, enmY, medshipRectC
		);
		enmArray ~= [ship];
		WriteLog("cur length:" ~ ToString(length(enmArray)));
		
		async{
			while(!Obj_IsDeleted(ship)){yield;}
			enmArray = remove(enmArray, ship);
			WriteLog("cur length after removal:" ~ ToString(length(enmArray)));
		}

		async{
			ObjEnemy_SetAutoDelete(ship, false);
			ObjRender_SetAngleZ(ship, 180);
			ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove, LERP_DECELERATE);
			wait(frameMove);
			ObjEnemy_SetAutoDelete(ship, true);

			task SpawnSpiralEnmC(xOffset, yOffset){

				NewSpawnSpiralWithOffset(
					ship, xOffset, yOffset,
					[2, 3, 4, 5][min(3, floor(rank/80))], 1,
					max(12, FUNC_LERP_SMOOTH(17, 12, rank/350)), 
					6 * (1.0015 ^ rank), 6 * (1.0015 ^ rank) * max(0.6, FUNC_LERP_SMOOTH(0.9, 0.6, rank/300)), max(3, FUNC_LERP_SMOOTH(6, 3, rank/350)),
					KEV_BULLET, HUE_RED, 1.5,
					startAng+0, spinDir
				);
				NewSpawnSpiralWithOffset(
					ship, xOffset, yOffset,
					[2, 3, 4, 5][min(3, floor(rank/80))], 1,
					max(12, FUNC_LERP_SMOOTH(17, 12, rank/350)), 
					6 * (1.0015 ^ rank), 6 * (1.0015 ^ rank) * max(0.6, FUNC_LERP_SMOOTH(0.9, 0.6, rank/300)), max(3, FUNC_LERP_SMOOTH(6, 3, rank/350)),
					KEV_BULLET, HUE_RED, 1.5,
					startAng+180, spinDir * (-1)
				);

			}

			SpawnSpiralEnmC(-96, 0);
			SpawnSpiralEnmC(96, 0);

			wait(frameMove * 3);
			ObjMove_SetDestAtFrame(ship, leaveX, leaveY, frameMove * 4, LERP_ACCELERATE);
		}

		return ship;

	}

	function <int> AimedEnemy(enmX, enmY, targetX, targetY, leaveX, leaveY, frameMove, rank){

		int ship = _SmallShip(
			42, frameMove,
			enmX, enmY, smallshipRectB
		);

		async{
			ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove, LERP_DECELERATE);
			wait(frameMove);
			FireTask();
			wait(frameMove * 2);
			ObjMove_SetDestAtFrame(ship, leaveX, leaveY, frameMove * 4, LERP_ACCELERATE);
		}

		task FireTask(){

			int bulletDel = max(10, FUNC_LERP_LINEAR(40, 10, rank/400));
			int bulletDense = [1, 3, 5][min(2, floor(rank/80))];
			float bulletAng = [0, 1.6, 1.0][min(2, floor(rank/80))];
			float bulletSpeed = 7.75 * (1.0005 ^ rank);

			while(!Obj_IsDeleted(ship)){
				NewCreateFan (ship, bulletDense, KEV_BULLET, HUE_CYAN, 1, 
				0, bulletAng, bulletSpeed, 1, 1.5,
				PATTERN_FAN_AIMED, false);
				Shoot2;
				wait(bulletDel);
				yield;
			}

			return;
		}

		return ship;

	}

	// 1
	
	MediumEnemyA(3 * STG_WIDTH/4 - 96 - 48, -128, 
				3 * STG_WIDTH/4 - 96 - 48, STG_HEIGHT/4,
				3 * STG_WIDTH/4 - 96 - 48, STG_HEIGHT + 128, 30, curRank);

	MediumEnemyA(3 * STG_WIDTH/4 + 96 - 48, -128, 
				3 * STG_WIDTH/4 + 96 - 48, STG_HEIGHT/3,
				3 * STG_WIDTH/4 + 96 - 48, STG_HEIGHT + 128, 30, curRank);

	MediumEnemyA(3 * STG_WIDTH/4 - 48, -128, 
				3 * STG_WIDTH/4 - 48, STG_HEIGHT/3 - 96,
				3 * STG_WIDTH/4 - 48, STG_HEIGHT + 128, 30, curRank);

	
	
	// 2

	wait(90);

	MediumEnemyB(1 * STG_WIDTH/4 - 96 + 48, -128, 
				1 * STG_WIDTH/4 - 96 + 48, STG_HEIGHT/3,
				1 * STG_WIDTH/4 - 96 + 48, STG_HEIGHT + 128, 30, 1, curRank);

	MediumEnemyB(1 * STG_WIDTH/4 + 96 + 48, -128, 
				1 * STG_WIDTH/4 + 96 + 48, STG_HEIGHT/1.9,
				1 * STG_WIDTH/4 + 96 + 48, STG_HEIGHT + 128, 30, -1, curRank);

	// 3

	wait(100);

	ascent(i in 0..3){

		MediumEnemyD(-96, STG_HEIGHT/8, 12, 10, curRank);
		MediumEnemyD(STG_WIDTH+96, STG_HEIGHT/8, 12, 180-10, curRank);
		wait(15);

	}

	wait(60);

	MediumEnemyB(1 * STG_WIDTH/4 - 96 + 48, STG_HEIGHT + 128, 
				1 * STG_WIDTH/4 - 96 + 48, 5 * STG_HEIGHT/8,
				1 * STG_WIDTH/4 - 96 + 48, -256, 22, 1, curRank);

	MediumEnemyB(3 * STG_WIDTH/4 + 96 - 48, STG_HEIGHT + 128, 
				3 * STG_WIDTH/4 + 96 - 48, 5 * STG_HEIGHT/8,
				3 * STG_WIDTH/4 + 96 - 48, -256, 22, 1, curRank);

	// 4

	wait(120);

	int enm = MediumEnemyE(1 * STG_WIDTH/4 - 24, -128, 
				1 * STG_WIDTH/4 - 24, STG_HEIGHT/5,
				1 * STG_WIDTH/4 - 24, STG_HEIGHT + 128, 25, 1, curRank, medEnemyHP * 4);

	// ObjEnemy_SetLife(enm, medEnemyHP * 3);

	wait(60);
	
	ascent(i in 0..15){

		float x = rand(1.4 * STG_WIDTH/4, 3.6 * STG_WIDTH/4);
		int enm = AimedEnemy(x, -36, x, STG_HEIGHT/4, x, STG_HEIGHT + 128, 15, curRank);
		ObjRender_SetAngleZ(enm, 180);
		wait(4);

	}

	int enm2 = MediumEnemyE(3 * STG_WIDTH/4 + 24, -128, 
				3 * STG_WIDTH/4 + 24, STG_HEIGHT/5,
				3 * STG_WIDTH/4 + 24, STG_HEIGHT + 128, 25, -1, curRank, medEnemyHP * 4);

	// ObjEnemy_SetLife(enm2, medEnemyHP * 3);

	wait(60);

	ascent(i in 0..15){

		float x = rand(0.4 * STG_WIDTH/4, 2.6 * STG_WIDTH/4);
		int enm = AimedEnemy(x, -36, x, STG_HEIGHT/4, x, STG_HEIGHT + 128, 15, curRank);
		ObjRender_SetAngleZ(enm, 180);
		wait(4);

	}

	wait(10);

	ascent(i in 0..20){

		float x = rand(0.2 * STG_WIDTH/4, 3.8 * STG_WIDTH/4);
		int enm = AimedEnemy(x, -36, x, STG_HEIGHT/4 + rand(-48, 48), x, STG_HEIGHT + 128, 15, curRank);
		ObjRender_SetAngleZ(enm, 180);
		wait(4);

	}

	ascent(i in 0..12){

		float y = rand(1.2 * STG_HEIGHT/4, 2.3 * STG_HEIGHT/4);
		int enm = AimedEnemy(-36, y, 1*STG_WIDTH/8 + rand(-32, 32), y, STG_WIDTH+64, y, 15, curRank);
		ObjRender_SetAngleZ(enm, 90);
		wait(4);

	}

	ascent(i in 0..12){

		float y = rand(1.2 * STG_HEIGHT/4, 2.3 * STG_HEIGHT/4);
		int enm = AimedEnemy(STG_WIDTH + 36, y, 7*STG_WIDTH/8 + rand(-32, 32), y, -64, y, 15, curRank);
		ObjRender_SetAngleZ(enm, 270);
		wait(4);

	}

	wait(60);

	int enm3 = LargeEnemyB(3 * STG_WIDTH/4 - 24, -128, 
				3 * STG_WIDTH/4 - 24, STG_HEIGHT/6,
				3 * STG_WIDTH/4 - 24, STG_HEIGHT + 128, 35, -1, curRank*1.25, 1600);

	//ObjEnemy_SetLife(enm3, medEnemyHP * 3.75);

	int enm4 = LargeEnemyB(1 * STG_WIDTH/4 + 24, -128, 
				1 * STG_WIDTH/4 + 24, STG_HEIGHT/6,
				1 * STG_WIDTH/4 + 24, STG_HEIGHT + 128, 35, 1, curRank*1.25, 1600);

	//ObjEnemy_SetLife(enm4, medEnemyHP * 3.75);

	wait(240);

}

function BossIntroB(){

	int[] enmArray = [];

	function <int> PopcornC(startX, moveAngle, rank){

		int ship = _SmallShip(
			42, 3,
			startX, -48, smallshipRectA
		);
		
		async{

			ObjEnemy_SetDamageRate(ship, 0.1, 0.1);

			while(!Obj_IsDeleted(ship) && ObjMove_GetY(ship) > 1 * STG_WIDTH/2){
				yield;
			}

			ObjEnemy_SetDamageRate(ship, 1, 1);

			if(Obj_IsDeleted(ship)){return;}
			FireTask();

		}

		async{

			ObjMove_SetAngle(ship, moveAngle);
			ObjRender_SetAngleZ(ship, moveAngle+90);
			ObjMove_SetSpeed(ship, 12);

		}

		task FireTask(){

			int bulletDel = max(15, FUNC_LERP_LINEAR(40, 15, rank/400));
			int bulletDense = [1, 3, 5][min(2, floor(rank/80))];
			float bulletAng = [0, 1.5, 1.0, 1.5][min(3, floor(rank/80))];
			float bulletSpeed = 7.25 * (1.0009 ^ rank);

			while(!Obj_IsDeleted(ship)){
				NewCreateFan (ship, bulletDense, KEV_BULLET, HUE_CYAN, 1, 
				0, bulletAng, bulletSpeed, 1, 1.5,
				PATTERN_FAN_AIMED, false);
				Shoot1;
				wait(bulletDel);
				yield;
			}

			return;

		}

		return ship;

	}

	function <int> MediumEnemyA(rect, hue, enmX, enmY, moveSpeed, moveAngle, zAngle, rank){

		int ship = _MediumShip(
			42, 15,
			enmX, enmY, rect,
			medEnemyHP * 0.75
		);

		async{

			ObjEnemy_SetAutoDelete(ship, false);
			ObjRender_SetAngleZ(ship, zAngle);
			ObjMove_AddPatternA1(ship, 0, moveSpeed, moveAngle);
			wait(15);
			FireTask();

		}

		task FireTask(){

			int bulletDel = max(20, FUNC_LERP_LINEAR(40, 20, rank/300));
			int bulletDense = min(24, FUNC_LERP_LINEAR(14, 24, rank/400));
			float bulletMaxSpeed = 10 * (1.0008 ^ rank);

			//float[][] bulletOffsets = [[0, -24], [-36, 24], [36, 24]];

			while(!Obj_IsDeleted(ship) && YMove(ship) > 0 && YMove(ship) < STG_HEIGHT){

				float x = XMove(ship) + rand(-48, 48);
				float y = YMove(ship) + rand(-48, 48);

				ascent(i in 0..bulletDense){

					Shoot1;
					int bullet = CreateHueShotA1(x, y, 0, i * (360/bulletDense), KEV_BULLET_ALT, hue, 1.5, 0);

					ObjMove_AddPatternA2(bullet, 0, 12, NO_CHANGE, -12/12, 1.5, 0);
					ObjMove_AddPatternA4(bullet, 30, NO_CHANGE, 0, bulletMaxSpeed/30, bulletMaxSpeed, 0, NO_CHANGE, GetPlayerObjectID());

					async{
						ObjShot_SetAutoDelete(bullet, false);
						wait(40);
						if(!Obj_IsDeleted(bullet)) ObjShot_SetAutoDelete(bullet, true);
						return;
					}

				}

				wait(bulletDel);
			}

			return;

		}

		return ship;

	}

	function <int> MediumEnemyB(rect, hue, enmX, enmY, moveSpeed, moveAngle, rank){

		int ship = _MediumShip(
			42, 30,
			enmX, enmY, rect
		);

		async{
			ObjEnemy_SetAutoDelete(ship, false);
			ObjMove_AddPatternA1(ship, 0, moveSpeed, moveAngle);
			wait(30);
			ObjEnemy_SetAutoDelete(ship, true);
			FireTask();
		}

		task FireTask(){

			int bulletDel = max(15, FUNC_LERP_LINEAR(35, 15, rank/400));
			int bulletDense = [2, 3, 4, 5, 6][min(4, floor(rank/60))];
			int bulletStack = [2, 3, 4, 5][min(3, floor(rank/80))];
			float bulletAng = min(21, 4 * (1.002 ^ rank));
			float bulletSpeed = 7.5 * (1.00062 ^ rank);

			while(!Obj_IsDeleted(ship)){
				NewCreateFan (ship, bulletDense, KEV_BULLET, hue, bulletStack, 
				0, bulletAng, bulletSpeed, bulletSpeed * 0.85, 1.5,
				PATTERN_FAN_AIMED, false);
				Shoot2;
				wait(bulletDel);
				yield;
			}

			return;
		}

		return ship;

	}

