
int[] enmArray = [];
bool isRankDemonstrationEnd = false;

function <int> AimedEnemy(enmX, enmY, targetX, targetY, frameMove, rank){

    int ship = _SmallShip(
        42, frameMove,
        enmX, enmY, smallshipRectA
    );

    async{
        ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove, LERP_DECELERATE);
        wait(frameMove);
        FireTask();
        wait(frameMove * 2);
        ObjMove_SetDestAtFrame(ship, targetX, STG_HEIGHT + 256, frameMove * 4, LERP_ACCELERATE);
    }

    task FireTask(){

        int bulletDel = max(10, FUNC_LERP_LINEAR(40, 10, rank/400));
        int bulletDense = [1, 3, 5][min(2, floor(rank/80))];
        float bulletAng = [0, 1.2, 1.4, 1.6, 2.0][min(4, floor(rank/60))];
        float bulletSpeed = 7.9 * (1.0009 ^ rank);

        while(!Obj_IsDeleted(ship)){
            CreateFan (ship, bulletDense, SHOT_BULLET_DMAGENTA, 1, 
            0, bulletAng, bulletSpeed, 1, 1,
            PATTERN_FAN_AIMED, false);
            Shoot2;
            wait(bulletDel);
            yield;
        }

        return;
    }

    return ship;

}

function <int> MediumEnemyA(enmX, enmY, targetX, targetY, leaveX, leaveY, frameMove, rank){

    int ship = _MediumShip(
        42, frameMove,
        enmX, enmY, medshipRectA
    );

    enmArray ~= [ship];
    WriteLog("cur length:" ~ ToString(length(enmArray)));
    
    async{
        while(!Obj_IsDeleted(ship)){yield;}
        enmArray = remove(enmArray, ship);
        WriteLog("cur length after removal:" ~ ToString(length(enmArray)));
    }

    async{
        ObjEnemy_SetAutoDelete(ship, false);
        ObjRender_SetAngleZ(ship, 180);
        ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove, LERP_DECELERATE);
        wait(frameMove);
        FireTask();
        ObjEnemy_SetAutoDelete(ship, true);
        wait(frameMove * 2);
        ObjMove_SetDestAtFrame(ship, leaveX, leaveY, frameMove * 4, LERP_ACCELERATE);
    }

    task FireTask(){
        
        enmArray ~= [ship];

        int bulletDel = max(10, FUNC_LERP_LINEAR(20, 10, rank/350));
        int bulletDense = min(36, FUNC_LERP_LINEAR(32, 48, rank/400));
        float bulletSpeed = 4 * (1.001 ^ rank);

        while(ObjEnemy_GetInfo(ship, INFO_LIFE) > 0){
            float offset = rand(-180, 180);
            ascent(i in 0..bulletDense){
                CreateShotA1(XMove(ship), YMove(ship), bulletSpeed, GetAngleToPlayer(ship) + i * 360/bulletDense + offset, SHOT_BULLET_DAQUA, 15);
            }
            Shoot1;
            wait(bulletDel);
            yield;
        }

        return;
    }

    return ship;

}

function <int> MediumEnemyB(enmX, enmY, targetX, targetY, leaveX, leaveY, frameMove, spinDir, rank){

    int ship = _MediumShip(
        42, frameMove,
        enmX, enmY, medshipRectA
    );

    async{
        ObjEnemy_SetAutoDelete(ship, false);
        ObjRender_SetAngleZ(ship, 180);
        ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove, LERP_DECELERATE);
        wait(frameMove);
        ObjEnemy_SetAutoDelete(ship, true);
        SpawnSpiral(
            ship,
            [1, 2, 3][min(2, floor(rank/80))], min(10, FUNC_LERP_SMOOTH(4, 10, rank/400)),
            max(6.5, FUNC_LERP_SMOOTH(9.0, 6.5, rank/350)), 
            6 * (1.002 ^ rank), 6 * (1.002 ^ rank) * 0.95, max(5, FUNC_LERP_SMOOTH(10, 5, rank/350)),
            SHOT_BULLET_DAQUA, 1,
            GetAngleToPlayer(ship), spinDir
        );
        wait(frameMove * 2);
        ObjMove_SetDestAtFrame(ship, leaveX, leaveY, frameMove * 4, LERP_ACCELERATE);
    }

    return ship;

}

function <int> Popcorn(enmX, enmY, rank){

    int ship = _SmallShip(
        42, 3,
        enmX, enmY, smallshipRectA
    );

    async{
        ObjMove_SetAngle(ship, GetAngleToPlayer(ship));
        ObjRender_SetAngleZ(ship, GetAngleToPlayer(ship) + 90);
        ObjMove_SetSpeed(ship, 12);
        wait(5);
        FireTask();
    }

    task FireTask(){

        int bulletDel = max(15, FUNC_LERP_LINEAR(40, 15, rank/400));
        int bulletDense = [1, 3, 5][min(2, floor(rank/80))];
        float bulletAng = [0, 1.5, 1.0, 1.5][min(3, floor(rank/80))];
        float bulletSpeed = 10 * (1.0001 ^ rank);

        while(!Obj_IsDeleted(ship)){
            CreateFan (ship, bulletDense, SHOT_BULLET_DMAGENTA, 1, 
            0, bulletAng, bulletSpeed, 1, 1,
            PATTERN_FAN_AIMED, false);
            Shoot1;
            wait(bulletDel);
            yield;
        }

        return;

    }

    return ship;

}

function Wave1A1(){
    
    bool end = false;

    async{
        ascent(i in 0..(48*3+30)){
            if(GetPlayerState() == STATE_DOWN){
                SetCommonData("Deaths", GetCommonData("Deaths", 0)+1);
            }
            yield;
        }
    }

    ascent(i in 0..8){
        int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 - 64, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7, 15, GetCommonDataPtr(POINTER_RANK, 1));
        ObjRender_SetAngleZ(enm, 180);
        wait(6);
    }

    wait(15);

    ascent(i in 0..8){
        int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 + 128, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7 + STG_HEIGHT/5, 15, GetCommonDataPtr(POINTER_RANK, 1));
        ObjRender_SetAngleZ(enm, 180);
        wait(6);
    }

    wait(15);

    ascent(i in 0..8){
        int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 - 64, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7, 15, GetCommonDataPtr(POINTER_RANK, 1));
        ObjRender_SetAngleZ(enm, 180);
        wait(6);
    }

    end = true;

}

function Wave1A2(){
    int enm = MediumEnemyA(STG_WIDTH/2, -64, STG_WIDTH/2, STG_HEIGHT/3, STG_WIDTH/2, STG_HEIGHT + 256, 50, curRank);
    ObjEnemy_SetLife(enm, 3250);

    while(ObjEnemy_GetInfo(enm, INFO_LIFE) > 0){
        if(GetPlayerState() == STATE_DOWN){
            SetCommonData("Deaths", GetCommonData("Deaths", 0)+1);
        }
        yield;
    }

}

function Wave1A3(){

    SetCommonData("Bursts", 0);

    bool end = false;

    int enm1 = MediumEnemyB(STG_WIDTH/4, -64, STG_WIDTH/4, STG_HEIGHT/3, STG_WIDTH/4, STG_HEIGHT + 256, 30, 1, curRank);
    int enm2 = MediumEnemyB(3*STG_WIDTH/4, -64, 3*STG_WIDTH/4, STG_HEIGHT/3, 3*STG_WIDTH/4, STG_HEIGHT + 256, 30, -1, curRank);

    ascent(i in 0..8){
        int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 - 64, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7, 15, GetCommonDataPtr(POINTER_RANK, 1));
        ObjRender_SetAngleZ(enm, 180);
        wait(6);
    }

    wait(15);

    ascent(i in 0..8){
        int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 + 128, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7 + STG_HEIGHT/5, 15, GetCommonDataPtr(POINTER_RANK, 1));
        ObjRender_SetAngleZ(enm, 180);
        wait(6);
    }

    wait(15);

    ascent(i in 0..8){
        int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 - 64, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7, 15, GetCommonDataPtr(POINTER_RANK, 1));
        ObjRender_SetAngleZ(enm, 180);
        wait(6);
    }

    end = true;

}

function Wave1A4(){
    while(GetScore() <= 500000000){

        ascent(i in 0..8){
            int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 - 64, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7, 15, GetCommonDataPtr(POINTER_RANK, 1));
            ObjRender_SetAngleZ(enm, 180);
            wait(6);
        }

        wait(15);

        MediumEnemyB(3*STG_WIDTH/4, -64, 3*STG_WIDTH/4, STG_HEIGHT/3, 3*STG_WIDTH/4, STG_HEIGHT + 256, 30, -1, curRank);

        ascent(i in 0..8){
            int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 + 128, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7 + STG_HEIGHT/5, 15, GetCommonDataPtr(POINTER_RANK, 1));
            ObjRender_SetAngleZ(enm, 180);
            wait(6);
        }

        wait(15);

        MediumEnemyB(STG_WIDTH/4, -64, STG_WIDTH/4, STG_HEIGHT/3, STG_WIDTH/4, STG_HEIGHT + 256, 30, 1, curRank);

        yield;
    }
}

task Wave1A4B(){
    while(!isRankDemonstrationEnd){

        ascent(i in 0..8){
            int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 - 64, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7, 15, GetCommonDataPtr(POINTER_RANK, 1));
            ObjRender_SetAngleZ(enm, 180);
            wait(7);
        }

        wait(15);

        MediumEnemyB(3*STG_WIDTH/4, -64, 3*STG_WIDTH/4, STG_HEIGHT/3, 3*STG_WIDTH/4, STG_HEIGHT + 256, 30, -1, curRank);

        ascent(i in 0..8){
            int enm = AimedEnemy(STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8 + 128, -48, STG_WIDTH/7 + i * (5*STG_WIDTH/6)/8, STG_HEIGHT/7 + STG_HEIGHT/5, 15, GetCommonDataPtr(POINTER_RANK, 1));
            ObjRender_SetAngleZ(enm, 180);
            wait(7);
        }

        wait(15);

        MediumEnemyB(STG_WIDTH/4, -64, STG_WIDTH/4, STG_HEIGHT/3, STG_WIDTH/4, STG_HEIGHT + 256, 30, 1, curRank);

        SetCommonDataPtr(POINTER_TRUERANK, clamp(GetCommonDataPtr(POINTER_TRUERANK, 1.0)+50, RankLimits[4][1], RankLimits[4][2]));

        yield;
    }
}

function Tutorial1A(){

    SetCommonData("Bursts", 0);

    async{
        while(true){
			if(
				GetCommonDataPtr(POINTER_BURSTGAUGE, 0) >= 100 &&
				GetVirtualKeyState(VK_SPELL) == KEY_PUSH &&
				GetCommonDataPtr(POINTER_BURSTMODE, false) == false
				)
            {
                SetCommonData("Bursts", GetCommonData("Bursts", 0)+1);
            }
            yield;
        }
    }

    TutorialText1A();
    SetCommonData("Deaths", 0);

    wait(30);

    // wave 1

    Wave1A1();
    wait(30);

    TutorialText1B();
    SetCommonData("Deaths", 0);

    Wave1A2();
    wait(45);
    
    DeleteShotAll(TYPE_ALL, TYPE_FADE);

    TutorialText1C();
    SetCommonData("Deaths", 0);

    SetAreaCommonData("Ingame", "BurstGauge", GetAreaCommonData("Ingame", "BurstGauge", 0)+100);
    Wave1A3();
    wait(45);

    TutorialText1D();

    SetCommonData("Bursts", 0);
    SetCommonData("Deaths", 0);
    Wave1A4();
    wait(45);

    TutorialText1E();
    wait(45);

}

function TutorialText1A(){

    string text1 = "Welcome to Starlit Reverie![r]This tutorial will teach you everything you need[r]to succeed in your heroic adventure.";

    string text2 = "First, let's focus on the basic controls.";

    string text3 = "Use the ARROW KEYS to move.[r]Hold the Z key to shoot your bullets.";

    string text4 = "Let's give it a go.[r]Destroy the enemies while dodging their bullets!";

    CreateTutorialText(
        text1,
        45,
        180, 30, 
        true
    );

    CreateTutorialText(
        text2,
        45,
        120, 30, 
        true
    );

    CreateTutorialText(
        text3,
        45,
        200, 30, 
        true
    );

    CreateTutorialText(
        text4,
        45,
        180, 30, 
        false
    );

}

