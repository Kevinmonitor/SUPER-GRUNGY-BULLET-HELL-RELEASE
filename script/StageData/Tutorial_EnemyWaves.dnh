function CreateTutorialText(
        string text,
        int timeAppear,
        int timeStay, int timeDisappear, 
        bool stopActionDuringText
    ){

    int objText = CreateTextObject(
        STG_WIDTH/2, STG_HEIGHT/2, 24,
        text, "Cartesian",
        0xFFFFFF, 0xFFFFFF,
        0x000000, 3,
        60
    );

    ObjText_SetHorizontalAlignment(objText, ALIGNMENT_CENTER);

    if(stopActionDuringText){

        ascent(i in 0..timeAppear){
            ObjRender_SetY(objText, FUNC_LERP_DECEL(STG_HEIGHT/2, STG_HEIGHT/4, i/timeAppear));
            ObjRender_SetAlpha(objText, FUNC_LERP_DECEL(0, 255, i/timeAppear));
            yield;
        }
        
        wait(timeStay);

        ascent(i in 0..timeDisappear){
            ObjRender_SetY(objText, FUNC_LERP_DECEL(STG_HEIGHT/4, 0, i/timeDisappear));
            ObjRender_SetAlpha(objText, FUNC_LERP_DECEL(255, 0, i/timeDisappear));
            yield;
        }

        Obj_Delete(objText);

    }

    else{

        ascent(i in 0..timeAppear){
            ObjRender_SetY(objText, FUNC_LERP_DECEL(STG_HEIGHT/2, STG_HEIGHT/4, i/timeAppear));
            ObjRender_SetAlpha(objText, FUNC_LERP_DECEL(0, 255, i/timeAppear));
            yield;
        }

        async{

            wait(timeStay);

            ascent(i in 0..timeDisappear){
                ObjRender_SetY(objText, FUNC_LERP_DECEL(STG_HEIGHT/4, 0, i/timeDisappear));
                ObjRender_SetAlpha(objText, FUNC_LERP_DECEL(255, 0, i/timeDisappear));
                yield;
            }

            Obj_Delete(objText);

        }

    }

}