task animateThatPlanet(){

	int frameX = 256;
	int frameY = 256;

	ObjRender_SetScaleXYZ(motherfuckingTerrenus, 0.5);
	// ObjRender_SetPosition(motherfuckingTerrenus, STG_WIDTH/2, STG_HEIGHT/2+128, 0);
	ObjRender_SetTextureFilter(motherfuckingTerrenus, FILTER_NONE, FILTER_NONE, FILTER_NONE);

	while(true){

		ascent(i in 1..16){
			ascent(f in 1..17){
				ObjSprite2D_SetSourceRect(motherfuckingTerrenus, frameX*(f-1)+1, frameY*(i-1)+1, frameX*f, frameY*i);
				wait(6);
				// WriteLog(f);
				// WriteLog(i);
			}
		}
		
		//wait(2);

	}

}

function <void> _MoonBaseBG(){

	bool isTransitioning = true;

	ObjRender_SetAlpha(baseImgWhite, 0);
	ObjRender_SetAlpha(baseImg, 255);

	//ObjRender_SetScaleXYZ(stageImg, 1);

	float scrollSpeed = 0;
	float maxscrollSpeed = -2.5;

	float curScroll = 0;
	float curScroll_Overlay = 0;

	async{

		while(isTransitioning){
		
			//ObjSprite2D_SetDestRect(stageImg, 0, 0, STG_WIDTH/2, STG_HEIGHT/2);
			ObjSprite2D_SetSourceRect(stageImg, 0, curScroll, 768, curScroll+1824);
			//ObjSprite2D_SetSourceRect(bossImg2, curScroll, 0, curScroll+1024, 1024);
			ObjSprite2D_SetSourceRect(postMidbossImg, 0, curScroll-1920, 960, curScroll);

			curScroll += scrollSpeed;

			scrollSpeed = max(maxscrollSpeed, scrollSpeed-0.14);

			yield;
		
		}
		
	}
	
	ObjRender_SetAlpha(bossImg2, 0);
	ObjRender_SetAlpha(postMidbossImg, 0);

	ascent(i in 0..35){
		ObjRender_SetAlpha(stageImg, Interpolate_Decelerate(0, alphaMax, i/35));
		yield;
	}

	async{
		
		while(!postMidbossBGStart){yield;}

		ascent(i in 0..60){
			ObjRender_SetAlpha(stageImg, Interpolate_Smooth(alphaMax, 0, i/60));
			maxscrollSpeed = Interpolate_Smooth(-2.5, 9, i/60);
			yield;
		}

		wait(30);

		ascent(i in 0..90){
			ObjRender_SetAlpha(postMidbossImg, Interpolate_Decelerate(0, alphaMax, i/90));
			yield;
		}

		while(!bossRoomBGStart){yield;}

		ascent(i in 0..3*60){
			ObjRender_SetAlpha(postMidbossImg, Interpolate_Smooth(alphaMax, 0, i/(3*60)));
			maxscrollSpeed = min(12.5, maxscrollSpeed + 0.08);
			yield;
		}

		isTransitioning = false;
		_BossRoom();
		
	}

	//NotifyEventAll(EV_START_MUSIC, 0);
	
}

