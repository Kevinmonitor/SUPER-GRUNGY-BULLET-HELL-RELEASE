function <void> _TutorialBG(){

	ObjRender_SetPosition(stageImgTutorial, STG_WIDTH/2, STG_HEIGHT/2, 1);
	ObjRender_SetPosition(baseImgTutorial, STG_WIDTH/2, STG_HEIGHT/2, 1);
	ObjSprite2D_SetDestCenter(stageImgTutorial);
	//ObjRender_SetScaleXYZ(stageImgTutorial, 1);
	
	Obj_SetRenderPriorityI(stageImgTutorial, 23);
	Obj_SetRenderPriorityI(baseImgTutorial, 20);

	float scrollSpeed = 0;
	float maxscrollSpeed = -4;

	float curScroll = 0;
	float curScroll_Overlay = 0;

	async{

		loop{
		
			//ObjSprite2D_SetDestRect(stageImgTutorial, [0, 0, STG_WIDTH/2, STG_HEIGHT/2]);
			ObjSprite2D_SetSourceRect(stageImgTutorial, curScroll, 0, curScroll+1493, 840);

			curScroll += scrollSpeed;

			scrollSpeed = max(maxscrollSpeed, scrollSpeed-0.04);

			yield;
		
		}
		
	}

	ascent(i in 0..60){
		ObjRender_SetAlpha(stageImgTutorial, Interpolate_Decelerate(0, alphaMax, i/60));
		yield;
	}

	wait(30);

}

function <void> Dialogue(){

	//ObjSound_Play(soundWarn);

	wait(30);
	
	int objText3 = CreateTextObject(
	
	STG_WIDTH/2, STG_HEIGHT/3-60, 80,
	" ", "Origami Mommy",
	0x72CBFF, 0x72CBFF,
	0x08007C, 10,
	71
	
	);
	
