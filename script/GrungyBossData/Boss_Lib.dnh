task _RenderSpellDetails(string attackName, int bonusOffset, int baseHP, bool showTime){

	int objScene = GetEnemyBossSceneObjectID();

	float multiplier = 0.0;
	int damage = 0;

	int nameText = CreateTextObject(
		STG_WIDTH - 32, 120, 18,
		attackName, "Bedstead",
		0xDDD4FF, 0xFFFFFF,
		0x2D0075, 3.5,
		31
	);
	
	int bonusText = CreateTextObject(
		STG_WIDTH - 32, 140+bonusOffset, 16,
		attackName, "Bedstead",
		0xFFFFFF, 0xFFFFFF,
		0x005796, 2,
		31
	);

	int timeText = CreateTextObject(
		32, 120+bonusOffset, 16,
		"", "Bedstead",
		0xFFFFFF, 0xFFFFFF,
		0x000000, 3,
		31
	);

	int bonusText1 = CreateTextObject(
		STG_WIDTH/2, STG_HEIGHT/3, 32,
		"", "Bedstead",
		0xFFA337, 0xFFFFFF,
		0x000000, 6,
		60
	);
	int bonusText2 = CreateTextObject(
		STG_WIDTH/2, STG_HEIGHT/3 + 32, 60,
		"", "Bedstead",
		0xFFA337, 0xFFFFFF,
		0x5D2408, 6,
		60
	);

	ObjText_SetFontBold(nameText, true);
	ObjText_SetFontBold(bonusText, true);
	ObjText_SetHorizontalAlignment(nameText, ALIGNMENT_RIGHT);
	ObjText_SetHorizontalAlignment(bonusText, ALIGNMENT_RIGHT);
	//ObjText_SetHorizontalAlignment(timeText, ALIGNMENT_LEFT);

	ObjText_SetHorizontalAlignment(bonusText1, ALIGNMENT_CENTER);
	ObjText_SetHorizontalAlignment(bonusText2, ALIGNMENT_CENTER);
	
	int[] textArray = [nameText, bonusText, timeText];
	float[] textXArray = [STG_WIDTH - 16, STG_WIDTH - 16, 16];
	float[] expandFrameXArray = [944 - 16, 944 - 16, 336 + 16];
	int indexArray = 0;

	for each (int text in textArray){
		
		Obj_SetRenderPriorityI(text, 78);
		
		if (GetAreaCommonData("Ingame", "IsExpandFrame", false)){
			ObjRender_SetX(text, expandFrameXArray[indexArray]);
		}

		indexArray++;

	}

	async{

		while(ObjEnemyBossScene_GetInfo(objScene, INFO_CURRENT_LIFE) > 0){
			
			if (showTime){
				ObjText_SetText(timeText, "TIME: " ~ rtos("000.00", ObjEnemyBossScene_GetInfo(objScene, INFO_TIMERF)/60));
			}
			// ObjText_SetText(timeText, "TIME: " ~ rtos("000.00", ObjEnemyBossScene_GetInfo(objScene, INFO_TIMERF)/60));

			damage = ObjEnemyBossScene_GetInfo(objScene, INFO_CURRENT_LIFE_MAX) - ObjEnemyBossScene_GetInfo(objScene, INFO_CURRENT_LIFE);
			multiplier = damage/baseHP;

			for each (int text in textArray){
				if(GetPlayerY() <= STG_HEIGHT/3){
					ObjRender_SetAlpha(text, 120);
				}	
				else{
					ObjRender_SetAlpha(text, 255);
				}
			}

			let score = trunc(GetCommonDataPtr(POINTER_SPELLSCORE, 10000000)/10) * 10;
			score = min(score,999999999990);
			let yass = DigitToCommaArray(score);
			ObjText_SetText(bonusText, "BONUS: " ~ yass ~ " x " ~ vtos("3.2f", multiplier));

			yield;
		}

		//ObjText_SetText(bonusText, "");
		ObjText_SetText(bonusText1, "BOSS ATTACK CLEAR!");
		ObjText_SetText(bonusText2, "+" ~ DigitToCommaArray(trunc(GetCommonDataPtr(POINTER_SPELLSCORE, 10000000)/10 * multiplier) * 10));
		
		ascent(i in 0..25){
			ObjRender_SetY(bonusText1, FUNC_LERP_DECEL(STG_HEIGHT/2 + 72, STG_HEIGHT/3 - 92, i/25));
			ObjRender_SetY(bonusText2, FUNC_LERP_DECEL(STG_HEIGHT/2 + 104, STG_HEIGHT/3 + 32 - 92, i/25));
			yield;
		}

		wait(40);

		Obj_Delete(bonusText1);
		Obj_Delete(bonusText2);

	}

}

task _SpellScoreHandling(int baseHP){

	// Decrease score per frame
	int objScene = GetEnemyBossSceneObjectID();
	int maxSpellScore = GetCommonDataPtr(POINTER_SPELLSCORE, 10000000);
	int minSpellScore = GetCommonDataPtr(POINTER_SPELLSCORE, 10000000)/10;
	int reductionPerFrame = (maxSpellScore - minSpellScore)/ObjEnemyBossScene_GetInfo(objScene, INFO_ORGTIMERF);
	//string multiplierText = "0";
	float multiplier = 0.0;

	int damage = 0;

	async{
		int frame = 0;
		while(ObjEnemyBossScene_GetInfo(objScene, INFO_CURRENT_LIFE) > 0){
			
			damage = ObjEnemyBossScene_GetInfo(objScene, INFO_CURRENT_LIFE_MAX) - ObjEnemyBossScene_GetInfo(objScene, INFO_CURRENT_LIFE);
			multiplier = damage/baseHP;
			//ObjText_SetText(multiplierText, vtos("3.2f", multiplier));
		
			SetCommonDataPtr(POINTER_SPELLSCORE, clamp(GetCommonDataPtr(POINTER_SPELLSCORE, 10000000), minSpellScore, maxSpellScore));

			yield;
		}
		AddScore( GetCommonDataPtr(POINTER_SPELLSCORE, 10000000) * multiplier );
	}

	// -10% if burst, -30% if take damage
	async{
		while(ObjEnemyBossScene_GetInfo(objScene, INFO_CURRENT_LIFE) > 0){
			if(
				GetPlayerState() == STATE_DOWN &&
				ObjEnemyBossScene_GetInfo(objScene, INFO_TIMERF) <= ObjEnemyBossScene_GetInfo(objScene, INFO_ORGTIMERF) - 30
			){
				SetCommonDataPtr(POINTER_SPELLSCORE, GetCommonDataPtr(POINTER_SPELLSCORE, 10000000) * 0.7);
				wait(90);
			}
			if(
				GetCommonDataPtr(POINTER_BURSTGAUGE, 0) >= 100 &&
				GetVirtualKeyState(VK_SPELL) == KEY_PUSH &&
				GetCommonDataPtr(POINTER_BURSTMODE, false) == false
				)
			{
				SetCommonDataPtr(POINTER_SPELLSCORE, GetCommonDataPtr(POINTER_SPELLSCORE, 10000000) * 0.9);
				wait(90);				
			}
			yield;
		}
	}

}

