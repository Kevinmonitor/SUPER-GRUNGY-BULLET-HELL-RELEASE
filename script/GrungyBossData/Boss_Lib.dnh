task _RenderBoss01(int enemy){

	let POINTER_BOSS = LoadCommonDataValuePointer("TrueBossReveal", false);

	int frame = 0;
	int idleframes = 5;

	// replace th9s
	int nameText = CreateTextObject(
		16, 12, 18,
		"test boss 01", "Bedstead",
		0x8034D3, 0xFFFFFF,
		0x000000, 3,
		78
	);
	
	ObjText_SetFontBold(nameText, true);
	
	ObjPrim_SetTexture(enemy, texBoss);
	ObjSprite2D_SetSourceRect(enemy, 0, 1024, 512, 1536);

	ObjSprite2D_SetDestCenter(enemy);
	ObjRender_SetScaleXYZ(enemy, 0.5);
	ObjRender_SetTextureFilterMin(enemy, FILTER_LINEAR);
	Obj_SetRenderPriorityI(enemy, 44);

	// texTrueBoss

	if (GetAreaCommonData("Ingame", "IsExpandFrame", false)){
		ObjRender_SetX(nameText, 336+16);
	}

	Obj_SetVisible(nameText, false);
	//_EnemyRenderIdle(enemy, 5, 0, 0, 720, 540, 6);

	while(!Obj_IsDeleted(enemy)){
		
		if(GetCommonDataPtr(POINTER_BOSS, false) == true){

			ObjPrim_SetTexture(enemy, texTrueBoss);
			//ObjSprite2D_SetSourceRect(enemy, 0, 1024, 512, 1536);

			_RenderEnemyMovement(enemy, frame, 0, 0, 616, 574, 4, 6);
			frame++;
			if (frame > 4*6){frame = 0;}

		}

		else{

			ObjPrim_SetTexture(enemy, texBoss);
			ObjSprite2D_SetSourceRect(enemy, 0, 1024, 512, 1536);

		}

		yield;

	}

}

