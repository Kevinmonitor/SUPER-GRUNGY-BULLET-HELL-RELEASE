int[] playerSilhouettes = [
	_Create2DImage(texBossEffect, [700, 0, 840, 170]),
	_Create2DImage(texBossEffect, [865, 0, 865+96, 115]),
	_Create2DImage(texBossEffect, [854, 144, 976, 288]),
	_Create2DImage(texBossEffect, [865, 0, 865+96, 115])
];

int bossSilhouette = _Create2DImage(texBossEffect, [0, 0, 720, 540]);
