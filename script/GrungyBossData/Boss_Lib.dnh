ObjRender_SetScaleXYZ(playerSilhouettes[1], 1.4);
ObjRender_SetScaleXYZ(playerSilhouettes[1], 1.1);

ascent(i in 0..4){
	ObjRender_SetAlpha(playerSilhouettes[i], 0);
}

task _RenderMidboss(int enemy){
	
	int frame = 0;
	int idleframes = 5;

	int nameText = CreateTextObject(
		16, 12, 18,
		"Starry-Eyed Cosmographer [Noah]", "Bedstead",
		0x0B9849, 0xFFFFFF,
		0x000000, 3,
		78
	);
	
	ObjText_SetFontBold(nameText, true);
	ObjPrim_SetTexture(enemy, texMidboss);
	ObjSprite2D_SetSourceRect(enemy, 0, 0, 244, 288);
	ObjSprite2D_SetDestCenter(enemy);
	ObjRender_SetScaleXYZ(enemy, 0.75);
	ObjRender_SetTextureFilterMin(enemy, FILTER_LINEAR);
	Obj_SetRenderPriorityI(enemy, 44);

	_EnemyRenderIdle(enemy, 5, 0, 288, 244, 288, 6);
	
}

task _RenderBoss(int enemy){
	
