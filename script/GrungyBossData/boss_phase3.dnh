		float posX =  STG_WIDTH/2 + 128 + rand(-64, 100);
		int enm = AimedEnemy(posX, -32, posX, bossY + rand(-128, 128), 12, curRank);
		Obj_SetRenderPriorityI(enm, 44);
		ObjRender_SetAngleZ(enm, 180);
		wait(6);
	}
    
    float despeAng = GetAngleToPlayer(bossObj);

	while
	(
		ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 154.480
	)
	{

		ascent(i in 0..8){

			int[] fan = NewCreateFan_ReturnArray (
				bossObj, [1, 1, 1, 1][diff], KEV_BULLET_ALT, HUE_RED,
				1, despeAng + i * 360/8, bulletspace * FUNC_LERP_LINEAR(1, 1.5, (5-length(homophobicCannons))/4), 
				bulletspd1, bulletspd1, 1.8,
				0, 0,
				PATTERN_FAN, false
			);

			for each(int bullet in ref fan){
				ObjMove_AddPatternA2(bullet, 0, bulletspd1*1.5, NO_CHANGE, -bulletspd1/18, bulletspd1/2, 0);
				ObjMove_AddPatternA2(bullet, 34, NO_CHANGE, NO_CHANGE, bulletspd1/45, bulletspd1, 0);
			}

		}

		despeAng += 9;

		Shoot1;

		wait(3);

	}

	BossEnding();

}

function _ReinitialiseOptions(){

	WriteLog(length(homophobicCannons));

	for each (int enm in homophobicCannons){
		if(ObjEnemy_GetInfo(enm, INFO_LIFE) <= 0){homophobicCannons = remove(homophobicCannons, enm);}
	}

	WriteLog(length(homophobicCannons));

	wait(5);

	// Do this before instantiating any pattern.
}

function _BossPattern1(count){

	_ReinitialiseOptions();

	int timer = 0;
    //float ang = dir == 1 ? 0 : 120;

    ascent( f in 0..count ){
         
		ascent(i in 0..[16, 18, 21, 24][diff]){

			int[] fan = NewCreateFan_ReturnArray (
				bossObj, [1, 2, 3, 4][diff], KEV_BULLET_ALT, HUE_RED,
				1, GetAngleToPlayer(bossObj) + i * 360/[16, 18, 21, 24][diff], [2, 2.4, 2.8, 2.6][curDiff], 
				bulletspd1, bulletspd1, 2.0,
				[-200, 200][f % 2 == 0 ? 0 : 1], -80,
				PATTERN_FAN, false
			);

			for each(int bullet in ref fan){
				ObjMove_AddPatternA2(bullet, 0, bulletspd1*3.4, NO_CHANGE, -bulletspd1/5, 2, 0);
				ObjMove_AddPatternA2(bullet, 34, NO_CHANGE, NO_CHANGE, bulletspd1/20, bulletspd1, 0);
				//ObjMove_AddPatternA1(bullet, 34, bulletspd1, NO_CHANGE);
			}

		}

        Shoot1;
        wait(17);

    }

	// while(timer < 17*24){
	// 	timer++; 
	// 	//if(length(homophobicCannons) < 1){break;}
	// 	yield;
	// }

}

function _BossPattern2(){

     float despeAng = GetAngleToPlayer(bossObj);

	_ReinitialiseOptions();

	//WriteLog((6-length(homophobicCannons))/5);

	int timer = 0;
	int enmValue = 0;
	
	//wait(FUNC_LERP_LINEAR(10, 5, curRankMult));

    ascent(i in 0..16){

        if(length(homophobicCannons) > 0){
            
            if (enmValue >= length(homophobicCannons)){enmValue = 0;}

            int[] fan = NewCreateFan_ReturnArray (
                homophobicCannons[enmValue], [7, 8, 9, 10][diff], KEV_BULLET_INV, HUE_AZURE,
                1, 0, [1.8, 2.0, 2.1, 2.4][curDiff], 
                bulletspd1, bulletspd1, 2.0,
                0, 0,
                PATTERN_FAN_AIMED, false
            );  

            enmValue += 1;

            Shoot2;

        }

        else{
            ascent(i in 0..7){

                int[] fan = NewCreateFan_ReturnArray (
                    bossObj, [1, 2, 3, 4][diff], KEV_BULLET_ALT, HUE_AZURE,
                    1, despeAng + i * 360/7, [1.15, 1.2, 1.4, 1.6][curDiff], 
                    bulletspd1, bulletspd1, 2.0,
                    0, 0,
                    PATTERN_FAN, false
                );

                for each(int bullet in ref fan){
                    ObjMove_AddPatternA2(bullet, 0, bulletspd1*1.8, NO_CHANGE, -bulletspd1/22, bulletspd1/2, 0);
                    //ObjMove_AddPatternA2(bullet, 45, NO_CHANGE, NO_CHANGE, bulletspd1/22, bulletspd1*1.5, 0);
                }

            }

            despeAng += 12;

            Shoot1;

        }

        wait(8);

    }

}

task _DancingCats(){

	int enemyA = 

	_CreateEnemy(
		-32, STG_HEIGHT-54, 
		-32, STG_HEIGHT-54, 
		5, 0.35, 0.4,
		777777, -1, -1,
		texBoss,
		[0, 0, 512, 512]
	);

	int enemyB = 

	_CreateEnemy(
		STG_WIDTH+32, STG_HEIGHT-54, 
		STG_WIDTH+32, STG_HEIGHT-54, 
		5, 0.35, 0.4,
		777777, -1, -1,
		texBoss,
		[0, 0, 512, 512]
	);

    int[] enms = [enemyA, enemyB];

    Obj_SetRenderPriorityI(enemyA, 39);
    Obj_SetRenderPriorityI(enemyB, 39);

    ObjEnemy_SetEnableIntersectionPositionFetching(enemyA, false);
    ObjEnemy_SetEnableIntersectionPositionFetching(enemyB, false);

    ObjEnemy_SetAutoDelete(enemyA, false);
    ObjEnemy_SetAutoDelete(enemyB, false);

    ObjRender_SetAngleY(enemyB, 180);

    ObjRender_SetAlpha(enemyA, 255);
    ObjRender_SetAlpha(enemyB, 255);
    
    async{ 
        ascent(i in 0..8){
            ObjMove_SetX(enemyA, FUNC_LERP_LINEAR(-32, 72, i/8));
            yield;
        }
    }

    async{ 
        ascent(i in 0..8){
            ObjMove_SetX(enemyB, FUNC_LERP_LINEAR(STG_WIDTH+32, STG_WIDTH-72, i/8));
            yield;
        }
    }

    wait(8);

    ascent(i in 0..47){
        for each (enm in enms){
            Dance(enm, XMove(enm), STG_HEIGHT-54);
        }
        wait(17);
    }

    task Dance(enm, x, y){
        ObjMove_SetDestAtFrame(enm, x, y - 48, 8, LERP_LINEAR);
        wait(8);
        ObjMove_SetDestAtFrame(enm, x, y, 7, LERP_LINEAR);
        wait(7);
    }

    ObjMove_SetDestAtFrame(enemyA, -128, STG_HEIGHT-54, 17, LERP_LINEAR);
    ObjMove_SetDestAtFrame(enemyB, STG_HEIGHT+128, STG_HEIGHT-54, 17, LERP_LINEAR);
}

task BossEnding(){

	// ObjSound_Seek(GetCommonData("currentBossSong", 0), 154);

	while
	(
		ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 154.480
	)
	{
		yield;
	}

	ObjEnemy_SetLife(bossObj, -1);

	float x = bossX;
	float y = bossY;

	// SetCommonData("midbossKillTime", GetCommonData("midbossKillTime", 0)+(ObjEnemyBossScene_GetInfo(objScene, INFO_ORGTIMERF) - ObjEnemyBossScene_GetInfo(objScene, INFO_TIMERF)));
	ObjSound_Play(bossGlassBreak);

	async{
		while(!Obj_IsDeleted(bossObj)){
			ObjMove_SetPosition(bossObj, x, y);
			ObjMove_CancelMovement(bossObj);
			yield;
		}
	}

	Obj_SetRenderPriorityI(bossObj, 40);
	DeleteShotAll(TYPE_ALL, TYPE_ITEM);
	NotifyEventAll(EV_BOSS_ATTACK_CLEAR, [bossX, bossY]);
	SetPlayerInvincibilityFrame(60);

	loop(68){
		yield;
	}

	Obj_Delete(bossObj);
	SetShotAutoDeleteClip(256, 256, 256, 256);
	CloseScript(GetOwnScriptID);
	
}