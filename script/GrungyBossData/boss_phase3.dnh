@Initialize {
	
	SetAutoDeleteObject(true);

	//SetAreaCommonData("Ingame", "Difficulty", "Legendary");

	diff = _InitDifficulty();
	ManageRankLimits(diff, false);
    
    curDiff = diff;

	// Create the boss object itself
	bossObj = ObjEnemy_Create(OBJ_ENEMY_BOSS); 
	ObjEnemy_Regist(bossObj);
	// ObjMove_SetPosition(bossObj, STG_WIDTH/2, STG_HEIGHT/3.5);
	ObjMove_SetDestAtFrame(bossObj, STG_WIDTH/2, STG_HEIGHT/3.5, 15, LERP_DECELERATE);

	ObjEnemyBossScene_StartSpell(objScene);
	//ObjEnemy_SetMaximumDamage(bossObj, 999);

	_RenderBoss01(bossObj);
    Obj_SetRenderPriorityI(bossObj, 41);

	mainTask();
	_FadeInvincibility(bossObj, 5, 80, 1);
	//BossEnding();

	SetCommonDataPtr(POINTER_SPELLSCORE, 1000000 * GetCommonDataPtr(POINTER_MULTIPLIER, 1.0));

	_RenderBossLife(bossObj, 40000, [0, 128, 600, 256], [0, 0, 0, 0], "SUPER POWERFUL PENMASTAH!!!");
	_RenderSpellDetails("\"PHASE 03 / 04\"", 0, 40000, false);
	_SpellScoreHandling(40000);

}

@Event {

	alternative(GetEventType())

	case(EV_REQUEST_LIFE) {
		SetScriptResult(777777);
	}
	
	case(EV_REQUEST_TIMER) {
		SetScriptResult(777);
	}
	
	case(EV_REQUEST_SPELL_SCORE){
		SetScriptResult(100);
	}

}

@MainLoop {

	playerY = GetPlayerY();
	playerX = GetPlayerX();
	//The player position is ALWAYS UPDATED 
	
	bossX = ObjMove_GetX(bossObj);
	bossY = ObjMove_GetY(bossObj);

	ObjEnemy_SetIntersectionCircleToShot(bossObj, ObjMove_GetX(bossObj), ObjMove_GetY(bossObj), 96);
	//WriteLog(ObjEnemy_GetInfo(bossObj, INFO_LIFE));

	curRankMult = GetCommonDataPtr(POINTER_RANK, 1.0)/255; // max 1
	curRank = GetCommonDataPtr(POINTER_RANK, 1.0);

	yield;
	
}


task mainTask {

	wait(5);
    ObjMove_SetDestAtFrame(bossObj, STG_WIDTH/2, 128, 30, LERP_DECELERATE);
	int dir = 1;

	WriteLog("wait done");

	BossEnding(); // debug
	StartPart2();

    Part1A();
    Part1B();
    Part1B();
    Part1C();

	while(ObjEnemy_GetInfo(bossObj, INFO_LIFE) > 0){

        yield;

	}
	// Refire initial semicircle
	
}

function Part1A{

    function <int> createStupidEvilGayBullet(float[] pos, float angle, float speed, float wvel, float del, hue){

        int evilGayBullet = CreateHueShotA1(pos[0], pos[1], speed, angle, KEV_BULLET_ALT, hue, 2.75, 0);
        ObjMove_SetAngularVelocity(evilGayBullet, wvel);
        ObjShot_SetSpellResist(evilGayBullet, true);

        async{
            while(!Obj_IsDeleted(evilGayBullet) && YMove(evilGayBullet) < STG_HEIGHT * 3/4){
                int evilGaySonOfBullet = CreateHueShotA1(XMove(evilGayBullet), YMove(evilGayBullet), speed*0.4, angle, KEV_BULLET, hue, 1.8, 0);
                ObjMove_SetAngularVelocity(evilGaySonOfBullet, -wvel*0.25);
                //Shoot2;
                wait(del);
            }
        }

        return evilGayBullet;
    }
    
    ascent(f in 0..4){
        ascent(i in 0..14){
            createStupidEvilGayBullet([bossX, bossY], i * 360/14, 7, 0.5 * (f % 2 == 0 ? 1 : -1), 6, HUE_BLUE);
        }
        wait(66);
    }

    ascent(f in 0..4){
        ascent(i in 0..14){
            createStupidEvilGayBullet([bossX, bossY], i * 360/14, 7.8, 0.8 * (f % 2 == 0 ? 1 : -1), 7, HUE_RED);
        }
        wait(66);
    }

    ObjMove_SetDestAtFrame(bossObj, STG_WIDTH/2, 180, 30, LERP_DECELERATE);

}

function Part1B(){

	wait(14);

	int[] explodingBulletArray = [];

	// 1

	float ang1 = rand(200, 210);
	float ang2 = rand(-20, -30);

	int evilCat1 = CreateHueShotA2(bossX, bossY, 18, ang1, -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
	explodingBulletArray ~= [evilCat1];
	wait(27);

	int evilCat2 = CreateHueShotA2(bossX, bossY, 18, ang2, -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
	explodingBulletArray ~= [evilCat2];
	wait(27);

	for each (int cat in ref explodingBulletArray){
		// fans
		int[] theGayFan = 

		NewCreateFan_ReturnArray
			(cat, 9, KEV_BULLET_INV, HUE_RED, 1, 
			0, 3, 13, 1, 2.0,
			0, 0,
			PATTERN_FAN_AIMED, false);
		
		NotifyEventAll(EV_EXPLODE, [XMove(cat), YMove(cat)]);
		Obj_Delete(cat);
	
	}

	// 2

	explodingBulletArray = [];

	wait(14);

	ascent(i in 0..3){
		int evilCat1 = CreateHueShotA2(bossX, bossY, 18, [rand(175, 185), rand(260, 280), rand(-20, 20)][i-1], -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
		explodingBulletArray ~= [evilCat1];
		wait(14);	
	}

	wait(13);

	for each (int cat in ref explodingBulletArray){
		// fans
		int[] theGayFan = 

		NewCreateFan_ReturnArray
			(cat, 9, KEV_BULLET_INV, HUE_RED, 1, 
			GetAngleToPlayer(cat), 3, 13, 1, 2.0,
			0, 0,
			PATTERN_FAN, false);
		NotifyEventAll(EV_EXPLODE, [XMove(cat), YMove(cat)]);
		Obj_Delete(cat);
	}

	// 3

	explodingBulletArray = [];

	wait(13);

	int evilCat3 = CreateHueShotA2(bossX, bossY, 18, ang2, -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
	explodingBulletArray ~= [evilCat3];
	wait(26);

	int evilCat4 = CreateHueShotA2(bossX, bossY, 18, ang1, -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
	explodingBulletArray ~= [evilCat4];
	wait(26);

	for each (int cat in ref explodingBulletArray){
		// fans
		int[] theGayFan = 

		NewCreateFan_ReturnArray
			(cat, 9, KEV_BULLET_INV, HUE_RED, 1, 
			0, 3, 13, 1, 2.0,
			0, 0,
			PATTERN_FAN_AIMED, false);
		
		NotifyEventAll(EV_EXPLODE, [XMove(cat), YMove(cat)]);
		Obj_Delete(cat);
	
	}

	// 4

	explodingBulletArray = [];

	wait(13);

	ascent(i in 0..4){
		int evilCat1 = CreateHueShotA2(bossX, bossY, 18, [rand(175, 185), rand(260, 280), rand(-20, 20)][i-1], -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
		explodingBulletArray ~= [evilCat1];
		wait(14);	
	}

	for each (int cat in ref explodingBulletArray){
		// fans
		int[] theGayFan = 

		NewCreateFan_ReturnArray
			(cat, 9, KEV_BULLET_INV, HUE_RED, 1, 
			GetAngleToPlayer(cat), 3, 13, 1, 2.0,
			0, 0,
			PATTERN_FAN, false);
		NotifyEventAll(EV_EXPLODE, [XMove(cat), YMove(cat)]);
		Obj_Delete(cat);
	}

	wait(7);

}

function Part1C(){

	int[] enmArray = [];

	ascent(i in 0..8){
		Popcorn(rand(STG_WIDTH/6, STG_WIDTH/3) + 67, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		Popcorn(rand(STG_WIDTH/6, STG_WIDTH/3) - 67, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		wait(7);
	}

	ascent(i in 0..8){
		Popcorn(rand(STG_WIDTH - STG_WIDTH/3, STG_WIDTH - STG_WIDTH/6) + 67, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		Popcorn(rand(STG_WIDTH - STG_WIDTH/3, STG_WIDTH - STG_WIDTH/6) - 67, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		wait(7);
	}

	ascent(i in 0..16){
		Popcorn(rand(STG_WIDTH/2 - 384, STG_WIDTH/2 + 384) + 128, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		Popcorn(rand(STG_WIDTH/2 - 384, STG_WIDTH/2 + 384) - 128, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		wait(7);
	}

	wait(35);

	LargeEnemyB(bossX - 120, -64, bossX - 120, bossY, bossX - 120, bossY, 21, 1, GetCommonDataPtr(POINTER_TRUERANK, 1.0), 1200, false);
	LargeEnemyB(bossX + 120, -64, bossX + 120, bossY, bossX + 120, bossY, 21, -1, GetCommonDataPtr(POINTER_TRUERANK, 1.0), 1500, true);

}

task StartPart2(){

	while
		(
			ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 135.675
		)
	{
		yield;
	}

	ascent(f in 0..2){
		ascent(i in 0..16){
			int shot = CreateHueShotA1(bossX, bossY, 40 * (0.8 ^ f), i * 360/16, KEV_BULLET_ALT_DARK, HUE_RED, 2.0, 0);
			ObjShot_SetAutoDelete(shot, false);
			ObjShot_SetDeleteFrame(shot, 120);
			ObjMove_AddPatternA2(shot, 0, NO_CHANGE, NO_CHANGE, -8, 2.5 * (0.9 ^ f), 1.2 * [-1, 1][f % 2 == 0 ? 0 : 1]);
			ObjMove_AddPatternA2(shot, 40, 17 * (0.9 ^ f), NO_CHANGE, 0, 17 * (0.9 ^ f), 0);
		}
	}

    wait(54);

    BuildGiantFuckingShip();

}

function <int> AimedEnemy(enmX, enmY, targetX, targetY, frameMove, rank){

	int ship = _SmallShip(
		42, frameMove,
		enmX, enmY, smallshipRectA
	);

	async{
		ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove, LERP_DECELERATE);
		wait(frameMove);
		FireTask();
		wait(frameMove * 2);
		ObjMove_SetDestAtFrame(ship, targetX, STG_HEIGHT + 256, frameMove * 4, LERP_ACCELERATE);
	}

	task FireTask(){

		int bulletDel = max(10, FUNC_LERP_LINEAR(40, 10, rank/400));
		int bulletDense = [1, 3, 5][min(2, floor(rank/80))];
		float bulletAng = [0, 1.2, 1.4, 1.6, 2.0][min(4, floor(rank/60))];
		float bulletSpeed = 8.0 * (1.001 ^ rank);

		while(!Obj_IsDeleted(ship)){
			NewCreateFan (ship, bulletDense, KEV_BULLET, HUE_RED, 1, 
			0, bulletAng, bulletSpeed, 1, 1.5,
			PATTERN_FAN_AIMED, false);
			Shoot2;
			wait(bulletDel);
			yield;
		}

		return;
	}

	return ship;

}

function <int> LargeEnemyB(enmX, enmY, targetX, targetY, leaveX, leaveY, frameMove, spinDir, rank, HP, bool cancel){

	int ship = _LargeShip(
		42, frameMove, 2400,
		enmX, enmY, medshipRectC, HP, cancel
	);

	async{
		ObjEnemy_SetAutoDelete(ship, false);
		ObjRender_SetAngleZ(ship, 180);
		ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove, LERP_DECELERATE);
		wait(frameMove);
		ObjEnemy_SetAutoDelete(ship, true);

		NewSpawnSpiralWithOffset(
			ship, -128, 0,
			[1, 2, 3][min(2, floor(rank/60))], min(8, FUNC_LERP_SMOOTH(3, 6, rank/400)),
			max(6.5, FUNC_LERP_SMOOTH(9.0, 6.5, rank/350)), 
			6 * (1.0015 ^ rank), 6 * (1.0015 ^ rank) * 0.9, max(4, FUNC_LERP_SMOOTH(7, 4, rank/350)),
			KEV_BULLET_INV, HUE_ROSE, 1.5,
			GetAngleToPlayer(ship), spinDir
		);
		NewSpawnSpiralWithOffset(
			ship, 128, 0,
			[1, 2, 3][min(2, floor(rank/60))], min(8, FUNC_LERP_SMOOTH(3, 6, rank/400)),
			max(6.5, FUNC_LERP_SMOOTH(9.0, 6.5, rank/350)), 
			6 * (1.0015 ^ rank), 6 * (1.0015 ^ rank) * 0.9, max(4, FUNC_LERP_SMOOTH(7, 4, rank/350)),
			KEV_BULLET_INV, HUE_ROSE, 1.5,
			GetAngleToPlayer(ship), spinDir * (-1)
		);

		wait(frameMove * 3);
		ObjMove_SetDestAtFrame(ship, leaveX, leaveY, frameMove * 4, LERP_ACCELERATE);
	}

	return ship;

}

function <int> Popcorn(enmX, enmY, rank){

	int ship = _SmallShip(
		42, 3,
		enmX, enmY, smallshipRectA
	);

	async{
		ObjMove_SetAngle(ship, GetAngleToPlayer(ship));
		ObjRender_SetAngleZ(ship, GetAngleToPlayer(ship) + 90);
		ObjMove_SetSpeed(ship, 15);
		wait(5);
		FireTask();
	}

	task FireTask(){

		int bulletDel = max(15, FUNC_LERP_LINEAR(40, 15, rank/400));
		int bulletDense = [1, 3, 5][min(2, floor(rank/80))];
		float bulletAng = [0, 1.5, 1.0, 1.5][min(3, floor(rank/80))];
		float bulletSpeed = 10 * (1.0001 ^ rank);

		while(!Obj_IsDeleted(ship)){
			NewCreateFan (ship, bulletDense, KEV_BULLET, HUE_RED, 1, 
			0, bulletAng, bulletSpeed, 1, 1.5,
			PATTERN_FAN_AIMED, false);
			Shoot1;
			wait(999);
			yield;
		}

		return;

	}

	return ship;

}

task _ReinitialiseValues(){

	curRankMult = GetCommonDataPtr(POINTER_RANK, 1.0)/255; // max 1
	curRank = GetCommonDataPtr(POINTER_RANK, 1.0);

    bulletspd1 = FUNC_LERP_LINEAR(9, 11, curRankMult) * FUNC_LERP_LINEAR(1, 1.1, (5-length(homophobicCannons))/4);
	bulletdel1 = [5, 4, 4, 3][min(3, floor(curRank/70))];
	bulletdel2 = FUNC_LERP_LINEAR(45, 30, (5-length(homophobicCannons))/4);
	
	bulletdense1 = FUNC_LERP_LINEAR(3, 5, (5-length(homophobicCannons))/4) + [0, 1, 1, 2][min(3, floor(curRank/80))];
	bulletspace = FUNC_LERP_LINEAR(5, 7, (5-length(homophobicCannons))/4) * (1 * FUNC_LERP_LINEAR(0.2, 1, min(1, curRankMult)));

	angleSpin = FUNC_LERP_LINEAR(25, 17, curRankMult) * FUNC_LERP_LINEAR(1, 0.8, (5-length(homophobicCannons))/4);

}

function <int> _HomophobicCannon(
	int renderPriority, invinTime,
	float enmX, float enmY, float HP,
	int cannonType
	){

	// Spawns enemy.

	//HP = 100;
	
	int spd = 5;
	
	int enm = _CreateEnemy(
	enmX, enmY, enmX, enmY, 1,
	0.65, 0.65,
	HP, 24, 0,
	texBoss,
	1664, [384, 640][cannonType], 1920, [640, 896][cannonType]);
	
	ObjRender_SetTextureFilter(enm, FILTER_NONE, FILTER_NONE, FILTER_NONE);
	Obj_SetRenderPriorityI(enm, renderPriority);

	int frame = 0;

	let objText = CreateTextObject(
		
		enmX, enmY - 128, 24,
		"", "Kenney Bold",
		0x59a933, 0xb9ff98,
		0xFFFFFF, 2,
		71
		
	);

	//ObjText_SetFontBorderType(objText, BORDER_NONE);
	Obj_SetRenderPriorityI(objText, 71);
	ObjText_SetHorizontalAlignment(objText, ALIGNMENT_CENTER);
	//ObjText_SetFixedWidth(objText, 8);

	LargeExplosion(enm, 32, 8);

	async{

		while(!Obj_IsDeleted(enm)){

			ObjRender_SetPosition(objText, MOVE_COORD(enm)[0], MOVE_COORD(enm)[1]-128, 1);

			// HP text show
			
			if(ObjEnemy_GetInfo(enm, INFO_LIFE) > 0){ObjText_SetText(objText, IntToString(ObjEnemy_GetInfo(enm, INFO_LIFE)));}
			else{ObjText_SetText(objText, "");}

			if(GetObjectDistance(objText, GetPlayerObjectID()) >= 64){ObjRender_SetAlpha(objText, 255);}
			else{ObjRender_SetAlpha(objText, 180);}

			// Deadzone
			invinTime--;
			if(ObjMove_GetY(enm) < deadZone || invinTime > 0){ObjEnemy_SetDamageRate(enm, 0, 0); ObjEnemy_SetLife(enm, HP);}
			else{ObjEnemy_SetDamageRate(enm, 1, 1);}

			yield;

		}

		Obj_SetVisible(objText, false);
		_ReinitialiseOptions();

		if(length(homophobicCannons) < 1){
			//DeleteShotAll(TYPE_ALL, TYPE_ITEM);
			ascent(i in 0..16){
				DeleteShotAll(TYPE_ALL, TYPE_ITEM);
				ObjSound_Play(bossBoom);
				wait(4);
			}
		}

	}

	_EnemyItemDrop(
		enm,
		verylargeFlyingEnm_itemPointMin, verylargeFlyingEnm_itemPointMax,
		128
	);
	
	return enm;
	
}

function <int> _CreateHomophobicCannon(
		float x, y, HP,
		int type
	){

	Lit2;

	int option = _HomophobicCannon(
		38, 90,
		x, y+64, HP, 
		type
	);

	Obj_SetRenderPriorityI(option, 41);

	// Move upwards and appear.

	async{
		ascent(i in 0..25){
			ObjMove_SetY(option, FUNC_LERP_DECEL(y+64, y, i/25));
			ObjRender_SetAlpha(option, FUNC_LERP_DECEL(125, 255, i/25));
			yield;
		}
	}

	homophobicCannons ~= [option];
	return option;

}

