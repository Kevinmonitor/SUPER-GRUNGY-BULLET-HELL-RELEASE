@Initialize {
	
	SetAutoDeleteObject(true);
	
	//SetAreaCommonData("Ingame", "Difficulty", "Legendary");

	diff = _InitDifficulty();
	ManageRankLimits(diff, false);
    
    curDiff = diff;

	// Create the boss object itself
	bossObj = ObjEnemy_Create(OBJ_ENEMY_BOSS); 
	ObjEnemy_Regist(bossObj);
	ObjMove_SetPosition(bossObj, STG_WIDTH/2, STG_HEIGHT/3.5);
	ObjMove_SetDestAtFrame(bossObj, STG_WIDTH/2, STG_HEIGHT/3.5, 1, LERP_DECELERATE);

	ObjEnemyBossScene_StartSpell(objScene);
	//ObjEnemy_SetMaximumDamage(bossObj, 999);

	_RenderBoss01(bossObj);

	mainTask();
	_FadeInvincibility(bossObj, 5, 80, 1);
	//BossEnding();

	SetCommonDataPtr(POINTER_SPELLSCORE, 1000000 * GetCommonDataPtr(POINTER_MULTIPLIER, 1.0));

	_RenderBossLife(bossObj, 40000, [0, 128, 600, 256], [0, 0, 0, 0], "SUPER POWERFUL PENMASTAH!!!");
	_RenderSpellDetails("\"PHASE 01 / 04\"", 0, 40000, false);
	_SpellScoreHandling(40000);

}

@Event {

	alternative(GetEventType())

	case(EV_REQUEST_LIFE) {
		SetScriptResult(777777);
	}
	
	case(EV_REQUEST_TIMER) {
		SetScriptResult(777);
	}
	
	case(EV_REQUEST_SPELL_SCORE){
		SetScriptResult(100);
	}

}

@MainLoop {

