function <int> AimedEnemy(enmX, enmY, targetX, targetY, frameMove, rank){

	int ship = _SmallShip(
		42, frameMove,
		enmX, enmY, smallshipRectA
	);

	async{
		ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove, LERP_DECELERATE);
		wait(frameMove);
		FireTask();
		wait(frameMove * 2);
		ObjMove_SetDestAtFrame(ship, targetX, STG_HEIGHT + 256, frameMove * 4, LERP_ACCELERATE);
	}

	task FireTask(){

		int bulletDel = max(10, FUNC_LERP_LINEAR(40, 10, rank/400));
		int bulletDense = [1, 3, 5][min(2, floor(rank/80))];
		float bulletAng = [0, 1.2, 1.4, 1.6, 2.0][min(4, floor(rank/60))];
		float bulletSpeed = 7.0 * (1.001 ^ rank);

		while(!Obj_IsDeleted(ship)){
			NewCreateFan (ship, bulletDense, KEV_BULLET, HUE_RED, 1, 
			0, bulletAng, bulletSpeed, 1, 1.5,
			PATTERN_FAN_AIMED, false);
			Shoot2;
			wait(bulletDel);
			yield;
		}

		return;
	}

	return ship;

}

function <int> LargeEnemyB(enmX, enmY, targetX, targetY, leaveX, leaveY, frameMove, spinDir, rank){

	int ship = _LargeShip(
		42, frameMove,
		enmX, enmY, medshipRectC
	);

	async{
		ObjEnemy_SetAutoDelete(ship, false);
		ObjRender_SetAngleZ(ship, 180);
		ObjMove_SetDestAtFrame(ship, targetX, targetY, frameMove, LERP_DECELERATE);
		wait(frameMove);
		ObjEnemy_SetAutoDelete(ship, true);

		NewSpawnSpiralWithOffset(
			ship, -96, 0,
			[1, 2, 3][min(2, floor(rank/60))], min(8, FUNC_LERP_SMOOTH(4, 8, rank/400)),
			max(6.5, FUNC_LERP_SMOOTH(9.0, 6.5, rank/350)), 
			5 * (1.0015 ^ rank), 5 * (1.0015 ^ rank) * 0.9, max(4, FUNC_LERP_SMOOTH(7, 4, rank/350)),
			KEV_BULLET, HUE_RED, 1.5,
			GetAngleToPlayer(ship), spinDir
		);
		NewSpawnSpiralWithOffset(
			ship, 96, 0,
			[1, 2, 3][min(2, floor(rank/60))], min(8, FUNC_LERP_SMOOTH(4, 8, rank/400)),
			max(6.5, FUNC_LERP_SMOOTH(9.0, 6.5, rank/350)), 
			5 * (1.0015 ^ rank), 5 * (1.0015 ^ rank) * 0.9, max(4, FUNC_LERP_SMOOTH(7, 4, rank/350)),
			KEV_BULLET, HUE_RED, 1.5,
			GetAngleToPlayer(ship), spinDir * (-1)
		);

		wait(frameMove * 3);
		ObjMove_SetDestAtFrame(ship, leaveX, leaveY, frameMove * 4, LERP_ACCELERATE);
	}

	return ship;

}

function <int> Popcorn(enmX, enmY, rank){

	int ship = _SmallShip(
		42, 3,
		enmX, enmY, smallshipRectA
	);

	async{
		ObjMove_SetAngle(ship, GetAngleToPlayer(ship));
		ObjRender_SetAngleZ(ship, GetAngleToPlayer(ship) + 90);
		ObjMove_SetSpeed(ship, 14);
		wait(5);
		FireTask();
	}

	task FireTask(){

		int bulletDel = max(15, FUNC_LERP_LINEAR(40, 15, rank/400));
		int bulletDense = [1, 3, 5][min(2, floor(rank/80))];
		float bulletAng = [0, 1.5, 1.0, 1.5][min(3, floor(rank/80))];
		float bulletSpeed = 10 * (1.0001 ^ rank);

		while(!Obj_IsDeleted(ship)){
			NewCreateFan (ship, bulletDense, KEV_BULLET, HUE_RED, 1, 
			0, bulletAng, bulletSpeed, 1, 1.5,
			PATTERN_FAN_AIMED, false);
			Shoot1;
			wait(999);
			yield;
		}

		return;

	}

	return ship;

}

function Opener(){

    int evilFadeToBlack = _Create2DImage("script/GrungyTextures/EvilDarkness.png", [0, 0, 1280, 720]);
    ObjRender_SetAlpha(evilFadeToBlack, 0);
    Obj_SetRenderPriorityI(evilFadeToBlack, 99);
    ObjRender_SetPosition(evilFadeToBlack, 1280/2, 720/2, 1);

    // roar followed by fade to black and then change to other UI
    // begin song

    NotifyEventAll(EV_BOSS_START_V1, 0);

    wait(120);

    async{
        // make him roar
        loop(3){
            ascent(i in 0..30){
                ObjRender_SetAngleZ(bossObj, Interpolate_Decelerate(0, -25, i/30));
                yield;
            }
            ascent(i in 0..50){
                ObjRender_SetAngleZ(bossObj, Interpolate_Accelerate(-25, 0, i/50));
                yield;
            }
            wait(75);
        }
    }

    // "open your eyes" 7 sec/420f after the roaring

    wait(280);

    ascent(i in 0..120){
        ObjRender_SetAlpha(evilFadeToBlack, Interpolate_Linear(0, 255, i/120));
        yield;
    }

    wait(35);

    ascent(i in 0..25){
        int shot = CreateHueShotA1(bossX, bossY, 60, i * 360/25, KEV_BULLET_ALT_DARK, HUE_RED, 2.0, 0);
        ObjMove_AddPatternA2(shot, 0, NO_CHANGE, NO_CHANGE, -11.5, 2.5, 0);
        ObjMove_AddPatternA2(shot, 40, 20, NO_CHANGE, 0, 20, 0);
    }

    wait(20);

    ObjRender_SetAlpha(evilFadeToBlack, 0);

	SetCommonData("TrueBossReveal", true);
    NotifyEventAll(EV_TRANSFORM_TO_GRUNGE);
    NotifyEventAll(EV_START_TRUE_FORM);

	wait(30);

}

function Part1A(){

	float[] xArray = [];
	float[] angArray = [];
	float[] yArray = [];

	// 1

	ascent(i in 0..12){
		xArray ~= [i * STG_WIDTH/12 + 16];
		angArray ~= [rand(87, 93)];
	}

	ascent(i in 0..12){
		_CreateCustomTelegraphLine( 
			xArray[i], -64, 48,
			angArray[i], angArray[i],
			0, STG_HEIGHT*1.1,
			21, 21,
			0xDE4848, 128,
			15, 60, 15
		);
		wait(2);
	}

	wait(34);

	ascent(i in 0..25){
		ascent(f in 0..12){
			int shot = CreateHueShotA1(xArray[f], -32, 48, angArray[f], KEV_BULLET_INV, HUE_RED, 2.5, 0);
		}
		wait(3);
	}

	// 2

	xArray = [];
	angArray = [];
	yArray = [];

	ascent(i in 0..12){
		xArray ~= [(12 - i) * STG_WIDTH/12];
		angArray ~= [180 + rand(87, 93)];
	}

	ascent(i in 0..12){
		_CreateCustomTelegraphLine( 
			xArray[i], STG_HEIGHT + 64, 48,
			angArray[i], angArray[i],
			0, STG_HEIGHT*1.1,
			21, 21,
			0xDE4848, 128,
			15, 60, 15
		);
		wait(2);
	}

	wait(34);

	ascent(i in 0..25){
		ascent(f in 0..12){
			int shot = CreateHueShotA1(xArray[f], STG_HEIGHT + 32, 48, angArray[f], KEV_BULLET_INV, HUE_RED, 2.5, 0);
		}
		wait(3);
	}

	// 3

	xArray = [];
	angArray = [];
	yArray = [];

	ascent(i in 0..12){
		yArray ~= [(12-i) * STG_HEIGHT/12];
		angArray ~= [rand(-3, 3)];
	}

	ascent(i in 0..12){
		_CreateCustomTelegraphLine( 
			-32, yArray[i], 48,
			angArray[i], angArray[i],
			0, STG_WIDTH*2,
			21, 21,
			0xDE4848, 128,
			15, 60, 15
		);
		wait(2);
	}

	wait(34);

	ascent(i in 0..25){
		ascent(f in 0..12){
			int shot = CreateHueShotA1(-32, yArray[f], 48, angArray[f], KEV_BULLET_INV, HUE_RED, 2.5, 0);
		}
		wait(3);
	}

	// 4

	xArray = [];
	angArray = [];
	yArray = [];

	ascent(i in 0..12){
		yArray ~= [i * STG_HEIGHT/12];
		angArray ~= [180+rand(-3, 3)];
	}

	ascent(i in 0..12){
		_CreateCustomTelegraphLine( 
			STG_WIDTH+32, yArray[i], 48,
			angArray[i], angArray[i],
			0, STG_WIDTH*2,
			21, 21,
			0xDE4848, 128,
			15, 60, 15
		);
		wait(2);
	}

	wait(34);

	ascent(i in 0..25){
		ascent(f in 0..12){
			int shot = CreateHueShotA1(STG_WIDTH+32, yArray[f], 48, angArray[f], KEV_BULLET_INV, HUE_RED, 2.5, 0);
		}
		wait(3);
	}

}

function Part1B(){

	wait(14);

	int[] explodingBulletArray = [];

	// 1

	float ang1 = rand(200, 210);
	float ang2 = rand(-20, -30);

	int evilCat1 = CreateHueShotA2(bossX, bossY, 18, ang1, -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
	explodingBulletArray ~= [evilCat1];
	wait(27);

	int evilCat2 = CreateHueShotA2(bossX, bossY, 18, ang2, -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
	explodingBulletArray ~= [evilCat2];
	wait(27);

	for each (int cat in ref explodingBulletArray){
		// fans
		int[] theGayFan = 

		NewCreateFan_ReturnArray
			(cat, 9, KEV_BULLET_INV, HUE_RED, 1, 
			0, 3, 13, 1, 2.0,
			0, 0,
			PATTERN_FAN_AIMED, false);
		
		NotifyEventAll(EV_EXPLODE, [XMove(cat), YMove(cat)]);
		Obj_Delete(cat);
	
	}

	// 2

	explodingBulletArray = [];

	wait(14);

	ascent(i in 0..3){
		int evilCat1 = CreateHueShotA2(bossX, bossY, 18, [rand(175, 185), rand(260, 280), rand(-20, 20)][i-1], -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
		explodingBulletArray ~= [evilCat1];
		wait(14);	
	}

	wait(13);

	for each (int cat in ref explodingBulletArray){
