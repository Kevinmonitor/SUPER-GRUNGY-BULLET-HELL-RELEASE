		int[] theGayFan = 

		NewCreateFan_ReturnArray
			(cat, 9, KEV_BULLET_INV, HUE_RED, 1, 
			GetAngleToPlayer(cat), 3, 13, 1, 2.0,
			0, 0,
			PATTERN_FAN, false);
		NotifyEventAll(EV_EXPLODE, [XMove(cat), YMove(cat)]);
		Obj_Delete(cat);
	}

	// 3

	explodingBulletArray = [];

	wait(13);

	int evilCat3 = CreateHueShotA2(bossX, bossY, 18, ang2, -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
	explodingBulletArray ~= [evilCat3];
	wait(26);

	int evilCat4 = CreateHueShotA2(bossX, bossY, 18, ang1, -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
	explodingBulletArray ~= [evilCat4];
	wait(26);

	for each (int cat in ref explodingBulletArray){
		// fans
		int[] theGayFan = 

		NewCreateFan_ReturnArray
			(cat, 9, KEV_BULLET_INV, HUE_RED, 1, 
			0, 3, 13, 1, 2.0,
			0, 0,
			PATTERN_FAN_AIMED, false);
		
		NotifyEventAll(EV_EXPLODE, [XMove(cat), YMove(cat)]);
		Obj_Delete(cat);
	
	}

	// 4

	explodingBulletArray = [];

	wait(13);

	ascent(i in 0..4){
		int evilCat1 = CreateHueShotA2(bossX, bossY, 18, [rand(175, 185), rand(260, 280), rand(-20, 20)][i-1], -1, 1, 0, KEV_CAT_RIP, HUE_RED, 1.25, 0);
		explodingBulletArray ~= [evilCat1];
		wait(14);	
	}

	for each (int cat in ref explodingBulletArray){
		// fans
		int[] theGayFan = 

		NewCreateFan_ReturnArray
			(cat, 9, KEV_BULLET_INV, HUE_RED, 1, 
			GetAngleToPlayer(cat), 3, 13, 1, 2.0,
			0, 0,
			PATTERN_FAN, false);
		NotifyEventAll(EV_EXPLODE, [XMove(cat), YMove(cat)]);
		Obj_Delete(cat);
	}

	wait(7);

}

function Part1C(){

	int[] enmArray = [];

	ascent(i in 0..8){
		Popcorn(rand(STG_WIDTH/6, STG_WIDTH/3) + 67, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		Popcorn(rand(STG_WIDTH/6, STG_WIDTH/3) - 67, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		wait(7);
	}

	ascent(i in 0..8){
		Popcorn(rand(STG_WIDTH - STG_WIDTH/3, STG_WIDTH - STG_WIDTH/6) + 67, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		Popcorn(rand(STG_WIDTH - STG_WIDTH/3, STG_WIDTH - STG_WIDTH/6) - 67, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		wait(7);
	}

	ascent(i in 0..16){
		Popcorn(rand(STG_WIDTH/2 - 384, STG_WIDTH/2 + 384) + 128, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		Popcorn(rand(STG_WIDTH/2 - 384, STG_WIDTH/2 + 384) - 128, -32, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
		wait(7);
	}

	wait(35);

	LargeEnemyB(bossX - 120, -64, bossX - 120, bossY, bossX - 120, bossY, 21, 1, GetCommonDataPtr(POINTER_TRUERANK, 1.0));
	LargeEnemyB(bossX + 120, -64, bossX + 120, bossY, bossX + 120, bossY, 21, -1, GetCommonDataPtr(POINTER_TRUERANK, 1.0));

}

task StartPart2(){

	// NotifyEventAll(EV_BOSS_START_V1, 0);
	// ObjSound_Seek(GetCommonData("currentBossSong", 0), 34); // debug
	
	while
		(
			ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 34.437
		)
	{
		yield;
	}

	ascent(f in 0..2){
		ascent(i in 0..16){
			int shot = CreateHueShotA1(bossX, bossY, 40 * (0.8 ^ f), i * 360/16, KEV_BULLET_ALT_DARK, HUE_RED, 2.0, 0);
			ObjShot_SetAutoDelete(shot, false);
			ObjShot_SetDeleteFrame(shot, 120);
			ObjMove_AddPatternA2(shot, 0, NO_CHANGE, NO_CHANGE, -8, 2.5 * (0.9 ^ f), 1.2 * [-1, 1][f % 2 == 0 ? 0 : 1]);
			ObjMove_AddPatternA2(shot, 40, 17 * (0.9 ^ f), NO_CHANGE, 0, 17 * (0.9 ^ f), 0);
		}
	}

    wait(84);

	// a giant ship with 4 cannons shows up
	BuildGiantFuckingShip();

}

function <int> _HomophobicCannon(
	int renderPriority, invinTime,
	float enmX, float enmY, float HP,
	int cannonType
	){

	// Spawns enemy.

	//HP = 100;
	
	int spd = 5;
	
	int enm = _CreateEnemy(
	enmX, enmY, enmX, enmY, 1,
	0.65, 0.65,
	HP, 24, 0,
	texBoss,
	1664, [384, 640][cannonType], 1920, [640, 896][cannonType]);
	
	ObjRender_SetTextureFilter(enm, FILTER_NONE, FILTER_NONE, FILTER_NONE);
	Obj_SetRenderPriorityI(enm, renderPriority);

	int frame = 0;

	let objText = CreateTextObject(
		
		enmX, enmY - 128, 24,
		"", "Kenney Bold",
		0x59a933, 0xb9ff98,
		0xFFFFFF, 2,
		71
		
	);

	//ObjText_SetFontBorderType(objText, BORDER_NONE);
	Obj_SetRenderPriorityI(objText, 71);
	ObjText_SetHorizontalAlignment(objText, ALIGNMENT_CENTER);
	//ObjText_SetFixedWidth(objText, 8);

	LargeExplosion(enm, 32, 8);

	async{

		while(!Obj_IsDeleted(enm)){

			ObjRender_SetPosition(objText, MOVE_COORD(enm)[0], MOVE_COORD(enm)[1]-128, 1);

			// HP text show
			
			if(ObjEnemy_GetInfo(enm, INFO_LIFE) > 0){ObjText_SetText(objText, IntToString(ObjEnemy_GetInfo(enm, INFO_LIFE)));}
			else{ObjText_SetText(objText, "");}

			if(GetObjectDistance(objText, GetPlayerObjectID()) >= 64){ObjRender_SetAlpha(objText, 255);}
			else{ObjRender_SetAlpha(objText, 180);}

			// Deadzone
			invinTime--;
			if(ObjMove_GetY(enm) < deadZone || invinTime > 0){ObjEnemy_SetDamageRate(enm, 0, 0); ObjEnemy_SetLife(enm, HP);}
			else{ObjEnemy_SetDamageRate(enm, 1, 1);}

			yield;

		}

		Obj_SetVisible(objText, false);
		_ReinitialiseOptions();

		if(length(homophobicCannons) < 1){
			//DeleteShotAll(TYPE_ALL, TYPE_ITEM);
			ascent(i in 0..16){
				DeleteShotAll(TYPE_ALL, TYPE_ITEM);
				ObjSound_Play(bossBoom);
				wait(4);
			}
		}

	}

	_EnemyItemDrop(
		enm,
		verylargeFlyingEnm_itemPointMin, verylargeFlyingEnm_itemPointMax,
		128
	);
	
	return enm;
	
}

function <int> _CreateHomophobicCannon(
		float x, y, HP,
		int type
	){

	Lit2;

	int option = _HomophobicCannon(
		38, 90,
		x, y+64, HP, 
		type
	);

	Obj_SetRenderPriorityI(option, 41);

	// Move upwards and appear.

	async{
		ascent(i in 0..25){
			ObjMove_SetY(option, FUNC_LERP_DECEL(y+64, y, i/25));
			ObjRender_SetAlpha(option, FUNC_LERP_DECEL(125, 255, i/25));
			yield;
		}
	}

	homophobicCannons ~= [option];
	return option;

}

task BuildGiantFuckingShip(){
	
	homophobicShip = 

	_CreateEnemy(
		STG_WIDTH/2, STG_HEIGHT+48, 
		STG_WIDTH/2, STG_HEIGHT+48, 
		5, 0.88, 0.88,
		7777777777, 0, 0,
		texBoss,
		[1024, 512, 1664, 896]
	);

	Obj_SetRenderPriorityI(homophobicShip, 40);

	async{
		ascent(i in 0..4){
			_CreateHomophobicCannon(
				[STG_WIDTH/2-200, STG_WIDTH/2-85, STG_WIDTH/2+85, STG_WIDTH/2+200][i], 
				[STG_HEIGHT/3 + 10, STG_HEIGHT/3 + 55, STG_HEIGHT/3 + 55, STG_HEIGHT/3 + 10][i], 2000, [0, 0, 1, 1][i]);
			wait(17);
		}
	}

	ascent(i in 0..64){
		ObjMove_SetY(homophobicShip, FUNC_LERP_DECEL(STG_HEIGHT+48, STG_HEIGHT/4.5, i/64));
		ObjMove_SetY(bossObj, FUNC_LERP_DECEL(STG_HEIGHT/3.5, STG_HEIGHT/3.5-54, i/64));
		yield;
	}

	_ReinitialiseValues();

	EvilGayAttack([-200, -80], 1, 1);
	EvilGayAttack([200, -45], -1, 1);

	task EvilGayAttack(float[] pos, int dir, float spdRate){

		float ang = dir == 1 ? 0 : 120;

		while(!Obj_IsDeleted(homophobicShip) && ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 52.198){
			
			ang = ang + (dir == 1 ? angleSpin : -angleSpin);
			 
			ascent(i in 0..3){

				int[] fan = NewCreateFan_ReturnArray (
					homophobicShip, bulletdense1, KEV_BULLET_ALT, HUE_AQUA, 1, 
					ang + i * 360/3, 1, spdRate * bulletspd1/1.4 * FUNC_LERP_LINEAR(1, 1.25, (5-length(homophobicCannons))/4), 
					spdRate * bulletspd1/1.4 * FUNC_LERP_LINEAR(1, 1.25, (5-length(homophobicCannons))/4), 1.75,
					pos[0], pos[1],
					PATTERN_FAN, false
				);

				for each (int bullet in ref fan){
					Obj_SetRenderPriorityI(bullet, 51);
				}

			}

			Shoot1;
			wait(bulletdel1*2);

		}

	}

	while(length(homophobicCannons) > 0 && ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 50.198){
		_ReinitialiseValues();
		_BossPattern1();
		_ReinitialiseValues();
		_BossPattern2();
		yield;
	}

	float despeAng = 0;

	while
	(
		ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 50.198
	)
	{

		ascent(i in 0..7){

			int[] fan = NewCreateFan_ReturnArray (
				bossObj, [1, 2, 3, 4][diff], KEV_BULLET_ALT, HUE_RED,
				1, despeAng + i * 360/7, [1.15, 1.2, 1.4, 1.6][curDiff], 
				bulletspd1, bulletspd1, 2.0,
				0, 0,
				PATTERN_FAN, false
			);

			for each(int bullet in ref fan){
				ObjMove_AddPatternA2(bullet, 0, bulletspd1*1.8, NO_CHANGE, -bulletspd1/22, bulletspd1/2, 0);
				//ObjMove_AddPatternA2(bullet, 45, NO_CHANGE, NO_CHANGE, bulletspd1/22, bulletspd1*1.5, 0);
			}

		}

		despeAng += 17.5;

		Shoot1;

		wait(17);

	}


	ObjMove_SetDestAtFrame(homophobicShip, STG_WIDTH/2, -48, 45, LERP_SMOOTH);
	if(length(homophobicCannons) > 0){
		for each (cannon in ref homophobicCannons){
			ObjMove_SetDestAtFrame(cannon, STG_WIDTH/2 + rand(-128, 128), -48, 45, LERP_SMOOTH);
		}
	}

	async{
		ascent(i in 0..45){
			if(length(homophobicCannons) > 0){
				for each (cannon in ref homophobicCannons){
					ObjRender_SetAlpha(cannon, FUNC_LERP_LINEAR(255, 0, i/45));
				}
			}
			ObjRender_SetAlpha(homophobicShip, FUNC_LERP_LINEAR(255, 0, i/45));
			yield;
		}
	}

	ascent(i in 0..8){
		float posX =  STG_WIDTH/2 - 128 + rand(-100, 64);
		int enm = AimedEnemy(posX, -32, posX, bossY + rand(-128, 128), 12, curRank);
		Obj_SetRenderPriorityI(enm, 44);
		ObjRender_SetAngleZ(enm, 180);
		wait(6);
	}

	ascent(i in 0..8){
		float posX =  STG_WIDTH/2 + 128 + rand(-64, 100);
		int enm = AimedEnemy(posX, -32, posX, bossY + rand(-128, 128), 12, curRank);
		Obj_SetRenderPriorityI(enm, 44);
		ObjRender_SetAngleZ(enm, 180);
		wait(6);
	}

	while
	(
		ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 53.018
	)
	{

		ascent(i in 0..7){

			int[] fan = NewCreateFan_ReturnArray (
				bossObj, [1, 1, 1, 1][diff], KEV_BULLET_ALT, HUE_RED,
				1, despeAng + i * 360/7, bulletspace * 1.25 * FUNC_LERP_LINEAR(1, 1.5, (5-length(homophobicCannons))/4), 
				bulletspd1, bulletspd1, 2.0,
				0, 0,
				PATTERN_FAN, false
			);

			for each(int bullet in ref fan){
				ObjMove_AddPatternA2(bullet, 0, bulletspd1*1.8, NO_CHANGE, -bulletspd1/18, bulletspd1/2, 0);
				ObjMove_AddPatternA2(bullet, 45, NO_CHANGE, NO_CHANGE, bulletspd1/22, bulletspd1, 0);
			}

		}

		despeAng += 12;

		Shoot1;

		wait(4);

	}

	BossEnding();

}

task _ReinitialiseValues(){

	curRankMult = GetCommonDataPtr(POINTER_RANK, 1.0)/255; // max 1
	curRank = GetCommonDataPtr(POINTER_RANK, 1.0);

    bulletspd1 = FUNC_LERP_LINEAR(9, 11, curRankMult) * FUNC_LERP_LINEAR(1, 1.1, (5-length(homophobicCannons))/4);
	bulletdel1 = [5, 4, 4, 3][min(3, floor(curRank/70))];
	bulletdel2 = FUNC_LERP_LINEAR(45, 30, (5-length(homophobicCannons))/4);
	
	bulletdense1 = FUNC_LERP_LINEAR(3, 5, (5-length(homophobicCannons))/4) + [0, 1, 1, 2][min(3, floor(curRank/80))];
	bulletspace = FUNC_LERP_LINEAR(5, 7, (5-length(homophobicCannons))/4) * (1 * FUNC_LERP_LINEAR(0.2, 1, min(1, curRankMult)));

	angleSpin = FUNC_LERP_LINEAR(25, 17, curRankMult) * FUNC_LERP_LINEAR(1, 0.8, (5-length(homophobicCannons))/4);

}

function _ReinitialiseOptions(){

	WriteLog(length(homophobicCannons));

	for each (int enm in homophobicCannons){
		if(ObjEnemy_GetInfo(enm, INFO_LIFE) <= 0){homophobicCannons = remove(homophobicCannons, enm);}
	}

	WriteLog(length(homophobicCannons));

	wait(5);

	// Do this before instantiating any pattern.
}

function _BossPattern1(){

	_ReinitialiseOptions();

	if(length(homophobicCannons) < 1){return;}

	//WriteLog((6-length(homophobicCannons))/5);

	int timer = 0;

	//wait(FUNC_LERP_LINEAR(10, 5, curRankMult));

	for each (int enm in homophobicCannons){

		Attack(enm);

	}

	task Attack(enm){

		int count = 0;

		while(!Obj_IsDeleted(enm) && timer < 17*8 && ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 50.198){

			float ang = GetAngleToPlayer(enm);

			ascent(i in 0..FUNC_LERP_LINEAR(3, 5, (5-length(homophobicCannons))/4)){

				int fan = NewCreateFan (
					enm, bulletdense1, count % 2 == 0 ? KEV_BULLET : KEV_BULLET, HUE_RED,
					1,  ang, bulletspace * FUNC_LERP_LINEAR(1, 1.5, (5-length(homophobicCannons))/4), 
					bulletspd1 * FUNC_LERP_LINEAR(1, 1.25, (5-length(homophobicCannons))/4), bulletspd1 * FUNC_LERP_LINEAR(1, 1.25, (5-length(homophobicCannons))/4), 2.0,
					PATTERN_FAN, false
				);

				Shoot1;
				wait(2);
			}

			count++;

			wait(bulletdel2);
		}

	}

	while(timer < 17*8){
		timer++; 
		if(length(homophobicCannons) < 1){break;}
		yield;
	}

}

function _BossPattern2(){

	_ReinitialiseOptions();

	if(length(homophobicCannons) < 1){return;}

	//WriteLog((6-length(homophobicCannons))/5);

	int timer = 0;
	int enmValue = 1;
	
	//wait(FUNC_LERP_LINEAR(10, 5, curRankMult));

	for each (int enm in homophobicCannons){

		Attack([XMove(enm), YMove(enm)], enm, enmValue);
		enmValue *= -1;

	}

	task Attack(float[] pos, enm, dir){

		int count = 0;
		float ang = rand(0, 360) + dir == 1 ? 0 : 180;

		while(!Obj_IsDeleted(enm) && timer < 17*8  && ObjSound_GetInfo(GetCommonData("currentBossSong", 0), INFO_POSITION) < 50.198){

			ascent(i in 0..14){

				_CreateCustomTelegraphLine( 
					pos[0], pos[1], 45,
					ang + i * 360/12 * (dir == 1 ? -1 : 1), ang + i * 360/12 * (dir == 1 ? -1 : 1),
					0, STG_HEIGHT*1.1,
					0, 32,
					0xDE4848, 150,
					25, 60, 25
				);

				LaserSFX;

				wait(3);

			}

			wait(17);

			ascent(i in 0..14){

				int laser = CreateHueLooseLaserA1(
					pos[0], pos[1], ang + i * 360/12 * (dir == 1 ? -1 : 1),
					368, 36, 24, KEV_BULLET_INV, HUE_RED, 1.5, 0
				);

				ObjRender_SetBlendType(laser, BLEND_ALPHA);

				LaserBSFX;

				wait(3);

			}


			//ang += 360/16 * (dir == 1 ? 1 : -1);

			wait(bulletdel2);
		}

	}

	while(timer < 17*8){
		timer++; 
		if(length(homophobicCannons) < 1){break;}
		yield;
	}

}

function BossEnding(){
	
	//NotifyEventAll(EV_BOSS_START_V1, 0);
	//ObjSound_Seek(GetCommonData("currentBossSong", 0), 54); // start phase 2 debug
	wait(30);

	Obj_SetRenderPriorityI(bossObj, 41);

	ObjEnemy_SetLife(bossObj, -1);

	float x = bossX;
	float y = bossY;

	// SetCommonData("midbossKillTime", GetCommonData("midbossKillTime", 0)+(ObjEnemyBossScene_GetInfo(objScene, INFO_ORGTIMERF) - ObjEnemyBossScene_GetInfo(objScene, INFO_TIMERF)));
	ObjSound_Play(bossGlassBreak);

	async{
		while(!Obj_IsDeleted(bossObj)){
			ObjMove_SetPosition(bossObj, x, y);
			ObjMove_CancelMovement(bossObj);
			yield;
		}
	}

	//Obj_SetRenderPriorityI(bossObj, 40);
	DeleteShotAll(TYPE_ALL, TYPE_ITEM);
	NotifyEventAll(EV_BOSS_ATTACK_CLEAR, [bossX, bossY]);
	SetPlayerInvincibilityFrame(60);

	loop(45){
		DeleteShotAll(TYPE_CHILD, TYPE_ITEM);
		yield;
	}

	Obj_Delete(bossObj);
	SetShotAutoDeleteClip(256, 256, 256, 256);
	CloseScript(GetOwnScriptID);
	
}