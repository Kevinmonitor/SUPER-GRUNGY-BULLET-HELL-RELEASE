task curEnmManage(){

	SetCommonData("Flying Loops Cleared", 0);
	SetCommonData("Ground Loops Cleared", 0);
	
	// RankManagement();
	//SetIntersectionVisualization(true);
	
	while(true){
		enmGround = [];
		enmFly = [];
		allEnm = GetIntersectionRegistedEnemyID();
		for each (int enm in ref allEnm){
			if(Obj_GetRenderPriorityI(enm) <= 37){enmGround ~= [enm];}
			else if(Obj_GetRenderPriorityI(enm) >= 38 && Obj_GetRenderPriorityI(enm) < 41){enmFly ~= [enm];}
			else{}
		}
		wait(3);
	}
	
}

task TStage
{

	async{

		while(GetPlayerState() != STATE_END)
		{
			yield;
		}

		EndBonus();

		NotifyEventAll(EV_END, true);
		loop(120){yield;}
		//ステージ終了
		CloseStgScene();

	}

	let bossFalse = LoadScriptInThread("script/GrungyBossData/false_boss_plural.dnh");
	let bossTrue = LoadScriptInThread("script/GrungyBossData/boss_plural.dnh");

    let dir = GetCurrentScriptDirectory();
	//SetIntersectionVisualization(true);
    //ボス再生

	CheckPlayerDeath();
	CityBackground01();

	wait(120);

	NotifyEventAll(EV_START_MUSIC, true);

	TOpener();
	NotifyEventAll(EV_TRANSFORM_TO_CUTE, 0);
	StartStageTimer();
	
	stage1Task();
	stage2Task();
	stage3Task();
	stage4Task();

	// boss time

	wait(120);
	while(stageTimer < 125 * 60){yield;}
	while(length(allEnm) > 0){yield;}

	//NotifyEventAll(EV_FADE_STAGE_MUSIC, 1);

	BossWarning();

	NotifyEventAll(EV_BOSS_CUTE_START, 0);
	StartScript(bossFalse);

    while(!IsCloseScript(bossFalse))
    {
        yield;
    }

	NotifyEventAll(EV_FADE_BOSS_MUSIC, 0);
    loop(30){yield;}

	CuteBossDialogue();

	wait(120);

	Obj_SetVisible(cuteBoss, false);
	Obj_SetVisible(cuterBoss, false);
	StartScript(bossTrue);

    while(!IsCloseScript(bossTrue))
    {
        yield;
    }

	EndBonus();

	NotifyEventAll(EV_END, true);
	loop(120){yield;}
	//ステージ終了
	CloseStgScene();
	
}

task StartStageTimer(){

	//stageTimer = 220*60; //debug

	while(true){

		stageTimer++;
		yield;

	}

}    

function CuteBossDialogue(){

	cuteBoss = 
	_CreateEnemy(
		STG_WIDTH/2, STG_HEIGHT/3.5,
		STG_WIDTH/2, STG_HEIGHT/3.5,
		5, 0.5, 0.5,
		9999999999999999, 1, 0,
		999999999,
		texEnm2,
		[0, 0, 512, 512]
	);

	cuterBoss = 
	_CreateEnemy(
		STG_WIDTH/2, STG_HEIGHT/3.5,
		STG_WIDTH/2, STG_HEIGHT/3.5,
		5, 0.5, 0.5,
		9999999999999999, 1, 0,
		999999999,
		texEnm2,
		[0, 1024, 512, 1536]
	);

	Obj_SetVisible(cuterBoss, false);

	wait(60);

	int objText = CreateTextObject(
	
		STG_WIDTH/15, STG_HEIGHT/2 - 24, 28,
		" ", "YomiyasuSansSerif",
		0xFFFFFF, 0xFFFFFF,
		0xFF007F, 4,
		71
	
	);
	
	ObjText_SetFontBold(objText, true);
	ObjText_SetHorizontalAlignment(objText, ALIGNMENT_LEFT);

	TTextScroll(objText, 
			
		"WOW!!!! YOU ARE SO POWERFUL OMG/|||
		I MUST PREPARE MY TRUE FORM/|||
		THERE WILL BE NO MORE CUTENESS/|||
		NOW I AM SUPER POWER!!!
		"

	);

	wait(90);

	async{
		ascent(i in 0..35){
			ObjRender_SetY(objText, FUNC_LERP_DECEL(STG_HEIGHT/2, -96, i/35));
			ObjRender_SetAlpha(objText, FUNC_LERP_LINEAR(255, 0, i/35));
			yield;
		}
		Obj_Delete(objText);
	}

	wait(110);

	async{
		ascent(i in 0..120){
			float[] pos = [ObjMove_GetX(cuteBoss) + rand(-96, 96), ObjMove_GetY(cuteBoss) + rand(-96, 96)];
			int bullet = CreateHueShotA1(
				ObjMove_GetX(cuteBoss), ObjMove_GetY(cuteBoss),
				16, atan2(pos[1] - ObjMove_GetY(cuteBoss), pos[0] - ObjMove_GetX(cuteBoss)),
				KEV_STAR, HUES[rand_int(0, 7)],
				3.0, 0
			);
			ObjShot_SetIntersectionEnable(bullet, false);
			ObjRender_SetBlendType(bullet, BLEND_ADD_ARGB);
			ObjShot_SetDeleteFrame(bullet, 20);
			Lit1;
			wait(2);
		}	
	}
	ascent(i in 0..120){
		float[] pos = [ObjMove_GetX(cuteBoss) + rand(-96, 96), ObjMove_GetY(cuteBoss) + rand(-96, 96)];
		int bullet = CreateHueShotA1(
			ObjMove_GetX(cuteBoss), ObjMove_GetY(cuteBoss),
			16, atan2(pos[1] - ObjMove_GetY(cuteBoss), pos[0] - ObjMove_GetX(cuteBoss)),
			KEV_STAR, HUES[rand_int(0, 7)],
			3.0, 0
		);
		ObjShot_SetIntersectionEnable(bullet, false);
		ObjRender_SetBlendType(bullet, BLEND_ADD_ARGB);
		ObjShot_SetDeleteFrame(bullet, 20);
		Lit1;
		wait(2);
	}
	
	ascent(i in 0..32){
		NotifyEventAll(EV_EXPLODE, [ObjMove_GetX(cuteBoss)+rand(-96, 96), ObjMove_GetY(cuteBoss)+rand(-96, 96)]);
	}

	ObjSound_Play(bossBoom);

	Obj_SetVisible(cuteBoss, false);
	Obj_SetVisible(cuterBoss, true);

	wait(120);

	int objText2 = CreateTextObject(
	
		STG_WIDTH/15, STG_HEIGHT/2 - 24, 28,
		" ", "YomiyasuSansSerif",
		0xFFFFFF, 0xFFFFFF,
		0xFF007F, 4,
		71
	
	);
	
	ObjText_SetFontBold(objText2, true);
	ObjText_SetHorizontalAlignment(objText2, ALIGNMENT_LEFT);

	TTextScroll(objText2, 
			
		"NOW I AM/|
		SUPER POWERFUL PENMASTAH!!!!!!!11/|
		BEHOLD MY POWER!!!!!111/|
		"

	);

	wait(90);

	async{
		ascent(i in 0..35){
			ObjRender_SetY(objText2, FUNC_LERP_DECEL(STG_HEIGHT/2, -96, i/35));
			ObjRender_SetAlpha(objText2, FUNC_LERP_LINEAR(255, 0, i/35));
			yield;
		}
		Obj_Delete(objText2);
	}

}


