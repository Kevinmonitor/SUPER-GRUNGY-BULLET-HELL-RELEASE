task THiScore(){
 	// New score system using rtos

 	// For score with zeroes at the end: Truncate score/10, and then multiply it by 10

	if(IsReplay() || LifeStart > 2){return;}

	let objScoreNo = ObjText_Create();
	ObjText_SetFontSize(objScoreNo, 30);
	ObjText_SetFontBold(objScoreNo, false);
	ObjText_SetFontType(objScoreNo, "Bedstead");
	ObjText_SetFontColorTop(objScoreNo, 0xFFFFFF);
	ObjText_SetFontColorBottom(objScoreNo, 0xFFFFFF);
	Obj_SetRenderPriorityI(objScoreNo, 82);
	ObjText_SetSidePitch(objScoreNo, 4);
	ObjText_SetFixedWidth(objScoreNo, 16);
	ObjRender_SetPosition(objScoreNo, 963, 329, 0);

	while(true){

		let score = trunc(hiScore/10) * 10;
		score = min(score,999999999990);

		if(hiScore < GetScore()){
			hiScore = GetScore();
		}

		let yass = DigitToCommaArray(score);
		ObjText_SetText(objScoreNo, yass);
		
		yield;

	}

}

task TDiffShow(){
 	// New score system using rtos

 	// For score with zeroes at the end: Truncate score/10, and then multiply it by 10

	int color = [0xD67600, 0x36DC00, 0x0071DB, 0xDB0070, 0xA800DB][GetAreaCommonData("Ingame", "DifficultyNo", 0)];

	let objScoreNo = ObjText_Create();
	ObjText_SetFontSize(objScoreNo, 24);
	ObjText_SetFontBold(objScoreNo, true);
	ObjText_SetFontType(objScoreNo, "Bedstead");
	ObjText_SetFontColorTop(objScoreNo, 0xFFFFFF);
	ObjText_SetFontColorBottom(objScoreNo, 0xFFFFFF);
	ObjText_SetFontBorderColor(objScoreNo, color);
	ObjText_SetFontBorderWidth(objScoreNo, 2);
	ObjText_SetFontBorderType(objScoreNo, BORDER_FULL);
	Obj_SetRenderPriorityI(objScoreNo, 82);
	//ObjText_SetSidePitch(objScoreNo, 2);
	ObjRender_SetPosition(objScoreNo, 963, 672, 0);
	ObjText_SetText(objScoreNo, DifficultyName[GetAreaCommonData("Ingame", "DifficultyNo", 0)]);

}

task CheckPlayerDeath(){

    while(GetPlayerState() != STATE_END){yield;}

	if(GetPlayerState() == STATE_END){
		NotifyEventAll(EV_END, true);
		loop(120){yield;}
		//ステージ終了
		CloseStgScene();
	}

}

function TOpener(){

	async{

		while(GetPlayerState() != STATE_END)
		{
			yield;
		}

		EndBonus();

		NotifyEventAll(EV_END, true);
		loop(120){yield;}
		//ステージ終了
		CloseStgScene();

	}

	SetCommonData("TrueBossReveal", false);

	Chapter1A();
	Chapter1D();
	wait(60);
	
	_CreateBulletColourShader();
	//Chapter1Bonus(); // bonus enemies
	
}

function BossWarning(){
	
	SetCommonData("BurstAllowed", false);

	int dangerA = _Create2DImage("script/StageData/StageLib/DangerA.png", [0, 0, 1000, 600]);
	int dangerB = _Create2DImage("script/StageData/StageLib/DangerB.png", [0, 0, 1000, 600]);

	int sfxWarning = ObjSound_Create();
	LoadEx(sfxWarning, "script/StageData/StageLib/stageMusic/bitch_warning.wav", 50);

	ObjSound_Play(sfxWarning);

	ObjRender_SetY(dangerA, STG_WIDTH/2 - 120);
	ObjRender_SetY(dangerB, STG_WIDTH/2 - 45);

	ObjRender_SetScaleXYZ(dangerA, 0.62);
	ObjRender_SetScaleXYZ(dangerB, 0.62);

	async{
		ascent(i in 0..35){
			ObjRender_SetX(dangerA, FUNC_LERP_DECEL(-64, STG_WIDTH/2, i/35));
			ObjRender_SetAlpha(dangerA, FUNC_LERP_LINEAR(0, 255, i/35));
			yield;
		}
	}

	async{
		ascent(i in 0..35){
			ObjRender_SetX(dangerB, FUNC_LERP_DECEL(STG_WIDTH + 64, STG_WIDTH/2, i/35));
			ObjRender_SetAlpha(dangerB, FUNC_LERP_LINEAR(0, 255, i/35));
			yield;
		}
	}

	wait(55);

	// async{
	// 	wait(55);
	// 	NotifyEventAll(EV_FADE_NORMAL_BG, 1);
	// }

	BossDialogue();
	
	async{
		ascent(i in 0..35){
			ObjRender_SetX(dangerA, FUNC_LERP_DECEL(STG_WIDTH/2, -350, i/35));
			ObjRender_SetAlpha(dangerA, FUNC_LERP_LINEAR(255, 0, i/35));
			yield;
		}
	}

	async{
		ascent(i in 0..35){
			ObjRender_SetX(dangerB, FUNC_LERP_DECEL(STG_WIDTH/2, STG_WIDTH + 350, i/35));
			ObjRender_SetAlpha(dangerB, FUNC_LERP_LINEAR(255, 0, i/35));
			yield;
		}
	}

	ObjSound_SetFade(sfxWarning, -25);
	wait(45);

	Obj_Delete(dangerA);
	Obj_Delete(dangerB);

	SetCommonData("BurstAllowed", true);

}

function <void> BossDialogue(){

	int objText = CreateTextObject(
	
		STG_WIDTH/15, STG_HEIGHT/2 - 24, 28,
		" ", "YomiyasuSansSerif",
		0xFFFFFF, 0xFFFFFF,
		0xFF007F, 4,
		71
	
	);
	
	ObjText_SetFontBold(objText, true);
	ObjText_SetHorizontalAlignment(objText, ALIGNMENT_LEFT);

	TTextScroll(objText, 
			
		"THE CUTEST HAUNTER/
		OF THE SCARY SHMUP/
		IS FAST APPROACHING/|
		/
		1. KAWAII SHOOTING ACTION/
		2. THERE'S NOTHING SCARY/
		3. RELAX/"

	);

	wait(110);

	async{
		ascent(i in 0..35){
			ObjRender_SetY(objText, FUNC_LERP_DECEL(STG_HEIGHT/2, -96, i/35));
			ObjRender_SetAlpha(objText, FUNC_LERP_LINEAR(255, 0, i/35));
			yield;
		}
		Obj_Delete(objText);
	}

}



