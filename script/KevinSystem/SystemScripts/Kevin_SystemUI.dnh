// New life task
task LifeDisplay(){

	let liferemain;
	let lifecounter = ObjPrim_Create(OBJ_SPRITE_LIST_2D);
	let lifeCounterMax = 9;
	let lifeCounterCount = 0;
	let lifeshow = graphicimg;
	Obj_SetRenderPriorityI(lifecounter, 82);
	ObjPrim_SetTexture(lifecounter, lifeshow);
	//ObjSpriteList2D_SetSourceRect(lifecounter, 256, 0, 384, 128);
	//ObjRender_SetScaleXYZ(lifecounter, 0.5, 0.5, 1);
	//ObjSpriteList2D_SetDestCenter(lifecounter);
	
	int maxText = CreateTextObject(
		1250, 445, 45,
		"ASCENSION", "YomiyasuSansSerif",
		0xFF9D9F, 0xFF9D9F,
		0x4C142B, 3.5,
		2
	);
	
	ObjText_SetHorizontalAlignment(maxText, ALIGNMENT_RIGHT);
	ObjText_SetFontBold(maxText, true);
	
	int MaxLife = GetCommonData("Life Limit", 99999); 
	
	loop{
		SetPlayerLife(min(MaxLife, GetPlayerLife()));
		
		ObjSpriteList2D_ClearVertexCount(lifecounter);
		ObjSpriteList2D_SetSourceRect(lifecounter, 0, 0, 64, 64);
		ObjRender_SetTextureFilterMag(lifecounter, FILTER_NONE);
		ObjSpriteList2D_SetDestCenter(lifecounter);
		ObjRender_SetScaleXYZ(lifecounter, 0.75);
		liferemain = GetPlayerLife();
		ascent(i in 0..liferemain){
			if (i >= lifeCounterMax){continue;}
			ObjRender_SetPosition(lifecounter, 1246-i*22, 412, 0);
			ObjSpriteList2D_AddVertex(lifecounter);	
			// lifeCounterCount++;	
		}
		yield;
	}

}

task BurstDisplay(){

	float GAUGE_WIDTH = 20;
	float GAUGE_LENGTH = 210;
	// Hyper gauge image creation and positioning
	int gauge = _Create2DImage(graphicimg, [64, 0, 320, 32]);
	ObjRender_SetTextureFilter(gauge, FILTER_NONE, FILTER_NONE, FILTER_NONE);
	ObjRender_SetPosition(gauge, 1155, 485, 0);
	Obj_SetRenderPriorityI(gauge, 82);
	// Gauge width: 9, gauge length: 78
	// Usage of primitives to create a bar with specified length
	let objI = CreateEffectObject(STG_WIDTH/60, STG_HEIGHT/7, "script/KevinSystem/img/Reverie_UI_Graphics.png", "ALPHA", 72, 38, 310, 56);
	ObjSprite2D_SetDestRect(objI, 0, 0, 250, 14);
	ObjRender_SetPosition(objI, 1050, 475, 0);
	Obj_SetRenderPriorityI(objI, 81);
	
	ObjRender_SetScaleXYZ(gauge, 0.85);

	// Manage the color of the gauge: gray normally, aqua blue when filled, gold when being consumed.

	task Flash(ID){
		ObjRender_SetColor(ID, 0x4CD2FF);
		wait(5);
		ObjRender_SetColor(ID, 0xFFFFFF);
		wait(5);
	}

	while(true){

		ObjSprite2D_SetDestRect(objI, 0, 0, (GetCommonDataPtr(POINTER_BURSTGAUGE, 1.0)/300)*GAUGE_LENGTH, GAUGE_WIDTH);
		SetCommonDataPtr(POINTER_BURSTGAUGE, clamp(GetCommonDataPtr(POINTER_BURSTGAUGE, 0), 0, 300)); 
		ObjRender_SetColor(objI, 0x69ECFF);
		yield;

	}

}

task SpellDisplay{

	SetPlayerSpell(2);

	int text = CreateTextObject(
	1745, 620, 25,
	"OVERLOAD", "YomiyasuSansSerif",
	0xFFFFFF, 0xFFB4F7,
	0x6600BE, 4,
	2
	);
	
	Obj_SetVisible(text, false);
	ObjText_SetSidePitch(text, -4); 
	ObjText_SetHorizontalAlignment(text, ALIGNMENT_CENTER);
	
	let spellremain;
	let spellcounter = ObjPrim_Create(OBJ_SPRITE_LIST_2D);
	let spellshow = graphicimg;
	Obj_SetRenderPriorityI(spellcounter, 82);
	ObjRender_SetScaleXYZ(spellcounter, 0.75);
	ObjPrim_SetTexture(spellcounter, spellshow);

	loop{

		if(GetPlayerSpell() > 9){SetPlayerSpell(9);}

		ObjSpriteList2D_ClearVertexCount(spellcounter);
		ObjSpriteList2D_SetSourceRect(spellcounter, 0, 64, 64, 128);
		ObjSpriteList2D_SetDestCenter(spellcounter);
		spellremain = GetPlayerSpell();
		ascent(i in 0..spellremain){
			ObjRender_SetPosition(spellcounter, 1246-i*22, 480, 0);
			ObjSpriteList2D_AddVertex(spellcounter);		
		}
		yield;

	}
}

