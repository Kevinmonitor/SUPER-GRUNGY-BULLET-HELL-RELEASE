}

function DigitToCommaArray(num){ //Natashinitai

	let srcStr = IntToString(num);
	let res = [];
	let nChar = 0;
	for(let i = length(srcStr) - 1; i >= 0; i--){
		res = [srcStr[i]] ~ res;
		nChar++;
		if(nChar % 3 == 0 && i > 0) res = "," ~ res;
	}
	return res;
	
}

function DigitToSpaceArray(num){ //Natashinitai

	let srcStr = IntToString(num);
	let res = [];
	let nChar = 0;
	for(let i = length(srcStr) - 1; i >= 0; i--){

		// if (i <= 4 && nChar > 11) res = "[font tc=(61, 61, 242)]" ~ res;
		// else if (i <= 4 && nChar <= 11 && nChar > 8) res = "[font tc=(189, 61, 242)]" ~ res;
		// else if (i <= 4 && nChar <= 8 && nChar > 5) res = "[font tc=(255, 194, 102)]" ~ res;
		// else if (i <= 4 && nChar <= 5 && nChar > 2) res = "[font tc=(102, 255, 194)]" ~ res;

		res = [srcStr[i]] ~ res;
		nChar++;

		if (nChar < 4) res = "[font tc=(255, 255, 255)]" ~ res;
		if (nChar >= 4 && nChar < 7) res = "[font tc=(102, 255, 194)]" ~ res;
		if (nChar >= 7 && nChar < 10) res = "[font tc=(255, 194, 102)]" ~ res;
		if (nChar >= 10 && nChar < 13) res = "[font tc=(189, 61, 242)]" ~ res;
		if (nChar >= 13) res = "[font tc=(61, 61, 242)]" ~ res;

		// if (nChar == 3) res = "[font tc=(255, 255, 255)]" ~ res;
		// if (nChar == 6) res = "[font tc=(102, 255, 194)]" ~ res;
		// if (nChar == 9) res = "[font tc=(255, 194, 102)]" ~ res;
		// if (nChar == 12) res = "[font tc=(189, 61, 242)]" ~ res;
		// if (nChar > 12) res = "[font tc=(61, 61, 242)]" ~ res;

	}
	return res;
	
}

function DigitToCommaArrayA(num){ //Natashinitai

	let srcStr = IntToString(num);
	let res = [];
	let nChar = 0;
	for(let i = length(srcStr) - 1; i >= 0; i--){
		res = [srcStr[i]] ~ res;
		nChar++;
		//if(nChar % 3 == 0 && i > 0) res = "," ~ res;
	}
	return res;
	
}

task ShowMultiplier(){
 	// New score system using rtos

 	// For score with zeroes at the end: Truncate score/10, and then multiply it by 10
	
	let objScoreNo = ObjText_Create();
	ObjText_SetFontSize(objScoreNo, 44);
	ObjText_SetFontBold(objScoreNo, true);
	ObjText_SetFontType(objScoreNo, "Bedstead");
	ObjText_SetFontColorTop(objScoreNo, 0xFFFFFF);
	ObjText_SetFontColorBottom(objScoreNo, 0x68CFFD);
	Obj_SetRenderPriorityI(objScoreNo, 82);
	ObjText_SetSidePitch(objScoreNo, 8);
	ObjText_SetFixedWidth(objScoreNo, 24);
	ObjRender_SetPosition(objScoreNo, 958, 303, 0);
	ObjText_SetHorizontalAlignment(objScoreNo, ALIGNMENT_LEFT);

	while(true){

		let score = trunc(GetCommonDataPtr(POINTER_MULTIPLIER, 1.0));
		//WriteLog(score);
		let yass = DigitToCommaArrayA(score);
		ObjText_SetText(objScoreNo, yass ~ "[f sz=30]x");
		
		wait(5);
		
	}

}

