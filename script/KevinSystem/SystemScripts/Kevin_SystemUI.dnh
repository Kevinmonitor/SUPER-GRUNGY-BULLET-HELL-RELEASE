task DetailUIDisplay(){

	// Detail UI
	int UI = _Create2DImage("script/KevinSystem/img/Reverie_DetailUI.png", [0, 0, 380, 300]);
	ObjRender_SetTextureFilter(UI, FILTER_NONE, FILTER_NONE, FILTER_NONE);
	ObjRender_SetPosition(UI, 167, 580, 0);
	Obj_SetRenderPriorityI(UI, 82);

	let hitCount = ObjText_Create();
	ObjText_SetFontSize(hitCount, 45);
	ObjText_SetFontBold(hitCount, true);
	ObjText_SetFontType(hitCount, "Bedstead");
	ObjText_SetFontColorTop(hitCount, 0xFFFFFF);
	ObjText_SetFontColorBottom(hitCount, 0xFFFFFF);
	ObjText_SetFontBorderType(hitCount, BORDER_FULL);
	ObjText_SetFontBorderColor(hitCount, 0xFF0E52);
	ObjText_SetFontBorderWidth(hitCount, 1);
	Obj_SetRenderPriorityI(hitCount, 82);
	ObjRender_SetPosition(hitCount, 73, 500, 0);
	ObjText_SetHorizontalAlignment(hitCount, ALIGNMENT_CENTER);

	let burstCount = ObjText_Create();
	ObjText_SetFontSize(burstCount, 45);
	ObjText_SetFontBold(burstCount, true);
	ObjText_SetFontType(burstCount, "Bedstead");
	ObjText_SetFontColorTop(burstCount, 0xFFFFFF);
	ObjText_SetFontColorBottom(burstCount, 0xFFFFFF);
	ObjText_SetFontBorderType(burstCount, BORDER_FULL);
	ObjText_SetFontBorderColor(burstCount, 0x0E92FF);
	ObjText_SetFontBorderWidth(burstCount, 1);
	Obj_SetRenderPriorityI(burstCount, 82);
	ObjRender_SetPosition(burstCount, 247, 500, 0);
	ObjText_SetHorizontalAlignment(burstCount, ALIGNMENT_CENTER);

	let destructionRate = ObjText_Create();
	ObjText_SetFontSize(destructionRate, 52);
	ObjText_SetFontBold(destructionRate, true);
	ObjText_SetFontType(destructionRate, "Bedstead");
	ObjText_SetFontColorTop(destructionRate, 0xFFFFFF);
	ObjText_SetFontColorBottom(destructionRate, 0xFFF5B7);
	ObjText_SetFontBorderType(destructionRate, BORDER_FULL);
	ObjText_SetFontBorderColor(destructionRate, 0x9C3208);
	ObjText_SetFontBorderWidth(destructionRate, 2);
	ObjText_SetSidePitch(destructionRate, -2);
	Obj_SetRenderPriorityI(destructionRate, 82);
	ObjRender_SetPosition(destructionRate, 204, 550, 0);
	ObjText_SetHorizontalAlignment(destructionRate, ALIGNMENT_CENTER);

	let destructionRateDecimals = ObjText_Create();
	ObjText_SetFontSize(destructionRateDecimals, 21);
	ObjText_SetFontBold(destructionRateDecimals, true);
	ObjText_SetFontType(destructionRateDecimals, "Bedstead");
	ObjText_SetFontColorTop(destructionRateDecimals, 0xFFFFFF);
	ObjText_SetFontColorBottom(destructionRateDecimals, 0xFFF5B7);
	ObjText_SetFontBorderType(destructionRateDecimals, BORDER_FULL);
	ObjText_SetFontBorderColor(destructionRateDecimals, 0x9C3208);
	ObjText_SetFontBorderWidth(destructionRateDecimals, 2);
	Obj_SetRenderPriorityI(destructionRateDecimals, 82);
	ObjRender_SetPosition(destructionRateDecimals, 262, 575, 0);
	ObjText_SetSidePitch(destructionRateDecimals, -1.5);
	ObjText_SetHorizontalAlignment(destructionRateDecimals, ALIGNMENT_CENTER);

	float destValue = GetCommonDataPtr(POINTER_ENEMYKILLED, 1) / GetCommonDataPtr(POINTER_ENEMYCOUNT, 1);
	int destInteger = trunc(destValue);
	float destDecimal = destValue - destInteger;

	while(true){

		destValue = GetCommonDataPtr(POINTER_ENEMYKILLED, 1) / GetCommonDataPtr(POINTER_ENEMYCOUNT, 1);
		destInteger = trunc(destValue*100);
		destDecimal = destValue*100 - trunc(destValue*100);

		ObjText_SetText(hitCount, GetCommonDataPtr(POINTER_DEATHCOUNT, 0));
		ObjText_SetText(burstCount, GetCommonDataPtr(POINTER_BURSTCOUNT, 0));
		ObjText_SetText(destructionRate, destInteger);
		ObjText_SetText(destructionRateDecimals, "." ~ vtos("02d", destDecimal*100));

		yield;

	}

}